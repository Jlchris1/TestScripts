-- Handle SummonTornado fired from client (client sends numeric params)
SummonTornadoEvent.OnServerEvent:Connect(function(player, params)
	pcall(function()
		if not isAllowedToUseCommands(player) then
			warn(("[SummonTornado] %s tried to summon but lacks permission."):format(player.Name)); return
		end
		if not params or type(params) ~= "table" then
			warn("[SummonTornado] invalid params from client."); return
		end
		-- Get spawn position from player's HRP (server-side)
		local spawnX, spawnZ = 0, 0
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local hrp = player.Character.HumanoidRootPart
			spawnX, spawnZ = hrp.Position.X, hrp.Position.Z
		else
			-- fallback: try head or 0,0
			if player.Character and player.Character:FindFirstChild("Head") then
				local head = player.Character.Head
				spawnX, spawnZ = head.Position.X, head.Position.Z
			else
				spawnX, spawnZ = 0, 0
			end
		end

		-- Validate and clamp server-side
		local fd = clamp(tonumber(params.funnelDiameter) or params.funnelDiameter or 300, CONFIG.FUNNEL_MIN_DIAMETER, CONFIG.FUNNEL_MAX_DIAMETER)
		local wr = clamp(tonumber(params.windfieldRadius) or params.windfieldRadius or math.max(fd + CONFIG.WINDFIELD_BUFFER, fd * 1.2), fd + CONFIG.WINDFIELD_BUFFER, fd * 12)
		local ws = clamp(tonumber(params.windspeedMPH) or params.windspeedMPH or 200, 1, 20000)
		local ms = clamp(tonumber(params.moveSpeed) or params.moveSpeed or 3, 0, 100)
		local ls = clamp(tonumber(params.lifespan) or params.lifespan or 420, CONFIG.TORNADO_LIFESPAN_MIN, CONFIG.TORNADO_LIFESPAN_MAX)

		print(("[Tornado] Summon request from %s -> spawn=(%.1f,%.1f) funnel=%s windfield=%s wind=%s move=%s life=%s")
			:format(player.Name, spawnX, spawnZ, tostring(fd), tostring(wr), tostring(ws), tostring(ms), tostring(ls)))

		-- Spawn tornado (server authoritative). immediateFormation true to skip long cloud-delay
		task.spawn(function()
			spawnTornadoAt(spawnX, spawnZ, {
				funnelDiameter = fd,
				windfieldRadius = wr,
				windspeedMPH = ws,
				moveSpeed = ms,
				lifespan = ls,
				ownerUserId = player.UserId,
			}, true)
		end)
	end)
end)

-- Handle live param updates from client (optional)
UpdateTornadoEvent.OnServerEvent:Connect(function(player, params)
	pcall(function()
		if not isAllowedToUseCommands(player) then return end
		if not params or type(params) ~= "table" then return end
		local rec = activeTornadoesByOwner[player.UserId]
		if not rec or not rec.applyParams then return end
		-- sanitize inputs
		local newParams = {}
		if params.funnelDiameter then newParams.funnelDiameter = clamp(tonumber(params.funnelDiameter) or params.funnelDiameter, CONFIG.FUNNEL_MIN_DIAMETER, CONFIG.FUNNEL_MAX_DIAMETER) end
		if params.windspeedMPH then newParams.windspeedMPH = clamp(tonumber(params.windspeedMPH) or params.windspeedMPH, 1, 20000) end
		if params.windfieldRadius then newParams.windfieldRadius = clamp(tonumber(params.windfieldRadius) or params.windfieldRadius, rec.params.funnelDiameter + CONFIG.WINDFIELD_BUFFER, rec.params.funnelDiameter * 12) end
		if params.moveSpeed then newParams.moveSpeed = clamp(tonumber(params.moveSpeed) or params.moveSpeed, 0, 100) end
		if params.lifespan then newParams.lifespan = clamp(tonumber(params.lifespan) or params.lifespan, CONFIG.TORNADO_LIFESPAN_MIN, CONFIG.TORNADO_LIFESPAN_MAX) end
		-- apply
		pcall(function() rec:applyParams(newParams) end)
	end)
end)

