-- ========== HELPER FUNCTIONS ==========
local function isPlayerPart(part)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character and part:IsDescendantOf(plr.Character) then return true end
    end
    return false
end

-- Check if part should be skipped due to being connected to an anchored part
local function isPartTetheredToAnchored(part)
    if part.Anchored then return true end
    return isConnectedToAnchored(part)
end

local function processPartForFunnel(obj)
    if obj:IsA("BasePart") and not obj.Anchored and not isPlayerPart(obj) and obj.Name ~= baseplateName then
        -- Skip parts that are welded/connected to an anchored part (they're tethered)
        if isPartTetheredToAnchored(obj) then return end
        if not whitelistedParts[obj] and not assignedToSatellite[obj] and not noodlePartSet[obj] and not mainFunnelSet[obj] and not ropeParts[obj] then
            pickedUpByFunnel[obj] = true; whitelistedParts[obj] = true
        end
    end
end

local function snapPartDown(part, targetY)
    if not part or not part.Parent then return end
    if debrisAttachedToPlayer[part] then return end
    local vel = part.AssemblyLinearVelocity
    part.AssemblyLinearVelocity = Vector3.new(vel.X, -math.abs(vel.Y) - math.abs(tornadoUpwardSpeed * 1.5), vel.Z)
end

local function reserveMainFunnelParts()
    mainFunnelParts = {}; mainFunnelSet = {}
    local candidates = {}
    for p in pairs(whitelistedParts) do
        if p and p.Parent and not p.Anchored and not assignedToSatellite[p] and not noodlePartSet[p] and not ropeParts[p] then
            local d = 0
            local center = tornadoPositions[1] or (localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") and localPlayer.Character.HumanoidRootPart.Position) or Vector3.new(0,10,0)
            if p.Position then d = (p.Position - center).Magnitude end
            table.insert(candidates, {part = p, dist = d})
        end
    end
    if #candidates == 0 then return end
    table.sort(candidates, function(a,b) return a.dist < b.dist end)
    local available = #candidates
    local desiredByShare = math.floor(available * mainFunnelShare + 0.5)
    local take = math.min(available, math.max(funnelReserveCount, desiredByShare))
    for i = 1, take do
        local p = candidates[i].part
        if p then
            mainFunnelParts[#mainFunnelParts + 1] = p; mainFunnelSet[p] = true
            whitelistedParts[p] = nil; pickedUpByFunnel[p] = nil; assignedToSatellite[p] = nil
        end
    end
end

-- ========== STABLE FORCE + MAIN FUNNEL WIDTH STRONG INWARD PULL + VERTICAL BOB ==========
local function applyFunnelForceToPart(part, centerPos, delta, isMain)
    if not part or not part.Parent then return end
    
    -- Re-check if the part is now tethered to an anchored part (could have been welded after pickup)
    if isPartTetheredToAnchored(part) then
        -- Don't apply velocity, it'll be moved by the weld. Remove from tracking so it gets re-checked later.
        return
    end
    
    local offset = part.Position - centerPos
    local horizontalOffset = Vector3.new(offset.X, 0, offset.Z)
    local distance = math.max(0.1, horizontalOffset.Magnitude)
    local dirToCenter = horizontalOffset.Unit
    local spinDir = Vector3.new(-dirToCenter.Z, 0, dirToCenter.X)

    local maxRadius = isMain and mainFunnelWidth or tornadoWindfield

    -- === FUNNEL WIDTH: STRONG INWARD PULL TO COUNTER SPIN ===
    -- The inward pull needs to directly counteract the centrifugal force from spin speed
    -- Formula: inward pull scales with spinSpeed^2 * distance / maxRadius (centrifugal counter)
    local centrifugalFactor = (tornadoSpinSpeed / 250) ^ 2  -- normalized to default
    local inwardStrength = tornadoSpinSpeed * 0.6 * centrifugalFactor * (1 + distance / math.max(1, maxRadius))
    
    -- Base inward pull
    local inwardPull = -dirToCenter * inwardStrength

    -- EXTRA INWARD FORCE when part exceeds the funnel width boundary
    local extraInward = 0
    if distance > maxRadius * 0.85 then
        -- Strong exponential pull-back when breaching the width limit
        local breach = (distance - maxRadius * 0.85) / math.max(1, maxRadius * 0.15)
        extraInward = breach * breach * tornadoSpinSpeed * 2.5
    end

    -- Spin velocity (tangential)
    local rotational = spinDir * (tornadoSpinSpeed * (0.8 + (distance / math.max(1, maxRadius)) * 0.2))

    -- Upward with vertical bob
    local upward = Vector3.new(0, tornadoUpwardSpeed, 0)
    local time = tick()
    local bobFreq = 1.5 + (distance / math.max(1, maxRadius)) * 0.5
    local anglePhase = math.atan2(offset.Z, offset.X) or 0
    local bobOffset = math.sin(time * bobFreq + anglePhase) * 8
    upward = upward + Vector3.new(0, bobOffset * delta * 3, 0)

    -- Assemble target velocity
    local targetVel = rotational + inwardPull + upward - dirToCenter * extraInward
    local currentVel = part.AssemblyLinearVelocity

    -- Smooth blend (higher factor = more responsive)
    local smoothFactor = math.min(1, delta * 8)
    local finalVel = currentVel:Lerp(targetVel, smoothFactor)

    if not part.Anchored then
        part.AssemblyLinearVelocity = finalVel
        part.CanCollide = false
    end
    return finalVel
end

local function updateMainFunnel(delta)
    if #tornadoPositions == 0 then return end
    local centerPos = tornadoPositions[1]
    for i, p in ipairs(mainFunnelParts) do
        if not p or not p.Parent then mainFunnelParts[i] = nil
        else
            local finalVel = applyFunnelForceToPart(p, centerPos, delta, true)
            if p.Position.Y >= (centerPos.Y + funnelHeight) then snapPartDown(p, centerPos.Y) end
        end
    end
    local newMain = {}
    for _, v in ipairs(mainFunnelParts) do if v then table.insert(newMain, v) end end
    mainFunnelParts = newMain
end

local function applyTornadoPhysics(position, delta)
    local parts = Workspace:GetPartBoundsInRadius(position, tornadoWindfield)
    for _, obj in ipairs(parts) do
        if obj:IsA("BasePart") and not obj.Anchored and not isPlayerPart(obj) and obj.Name ~= baseplateName then
            processPartForFunnel(obj)
            if whitelistedParts[obj] and not assignedToSatellite[obj] and not noodlePartSet[obj] and not mainFunnelSet[obj] and not ropeParts[obj] then
                -- Re-check tether before applying physics (in case weld was added after initial pickup)
                if not isPartTetheredToAnchored(obj) then
                    applyFunnelForceToPart(obj, position, delta, false)
                    if obj.Position.Y >= (position.Y + funnelHeight) and not debrisAttachedToPlayer[obj] then snapPartDown(obj, position.Y) end
                end
            end
        end
    end
end

-- ========== ROPE TORNADO — Aligned line of parts that wiggles ==========
local function spawnRopeTornado()
    -- Clean up old rope parts
    for part in pairs(ropeParts) do if part and part.Parent then part.AssemblyLinearVelocity = Vector3.zero; part.CanCollide = true; ropeParts[part] = nil end end
    ropeSegments = {}
    if #tornadoPositions == 0 then return end
    
    local available = {}
    for p in pairs(whitelistedParts) do 
        if p and p.Parent and not p.Anchored and not isPartTetheredToAnchored(p) then 
            table.insert(available, p) 
        end 
    end
    if #available == 0 then return end

    for ti, centerPos in ipairs(tornadoPositions) do
        local numRopes = math.max(1, math.min(6, math.floor(#available / 4)))
        
        for r = 1, numRopes do
            local angleOffset = (r / numRopes) * math.pi * 2
            local ropeLength = math.random(5, 12)   -- number of parts in this rope line
            local spacing = math.random(4, 8)        -- studs between each part
            local ropeDist = math.random(8, math.max(12, subVortexWidth * 0.3))
            
            local ropeLine = {}
            
            for s = 1, ropeLength do
                if #available == 0 then break end
                local idx = math.random(1, #available)
                local p = table.remove(available, idx)
                if p and p.Parent then
                    ropeParts[p] = true
                    whitelistedParts[p] = nil
                    pickedUpByFunnel[p] = nil
                    assignedToSatellite[p] = nil
                    mainFunnelSet[p] = nil
                    
                    -- Each part sits along a rope line extending upward and slightly outward
                    local t = (s - 1) / math.max(1, ropeLength - 1)  -- 0 to 1 along rope
                    local baseHeight = s * spacing
                    local spreadOut = 1 + t * 0.3  -- wider at top
                    
                    local baseX = math.cos(angleOffset + t * 0.5) * ropeDist * spreadOut
                    local baseZ = math.sin(angleOffset + t * 0.5) * ropeDist * spreadOut
                    
                    -- Unique wiggle parameters per part for natural snake motion
                    local phase = math.random() * math.pi * 2
                    local freq = 0.8 + math.random() * 1.5
                    local amp = math.random(3, 8 + s * 0.5)  -- more wiggle at tips
                    local phase2 = math.random() * math.pi * 2
                    local freq2 = 0.4 + math.random() * 0.8
                    local amp2 = math.random(2, 5)
                    
                    table.insert(ropeLine, {
                        part = p,
                        segmentIndex = s,
                        ropeLength = ropeLength,
                        spacing = spacing,
                        baseOffset = Vector3.new(baseX, baseHeight, baseZ),
                        angleOffset = angleOffset,
                        t = t,
                        wigglePhase = phase,
                        wiggleFreq = freq,
                        wiggleAmp = amp,
                        wigglePhase2 = phase2,
                        wiggleFreq2 = freq2,
                        wiggleAmp2 = amp2,
                        -- For alignment: keep a relative offset from the part below
                        prevPart = nil,  -- will link after
                    })
                end
            end
            
            -- Link parts in the rope line
            for i, seg in ipairs(ropeLine) do
                if i > 1 then
                    seg.prevPart = ropeLine[i - 1].part
                end
                table.insert(ropeSegments, seg)
            end
        end
    end
end

local function updateRopeTornado(delta)
    if #tornadoPositions == 0 then return end
    local time = tick()
    
    -- Build a lookup for segments grouped by tornado position affinity
    for _, seg in ipairs(ropeSegments) do
        local p = seg.part
        if not p or not p.Parent or isPartTetheredToAnchored(p) then continue end
        
        -- Find nearest tornado center
        local centerPos = tornadoPositions[1]
        local bestDist = math.huge
        for _, tp in ipairs(tornadoPositions) do
            local d = (p.Position - tp).Magnitude
            if d < bestDist then bestDist = d; centerPos = tp end
        end
        
        -- === WIGGLE CALCULATION ===
        -- Primary sine wave along the rope
        local w1 = math.sin(time * seg.wiggleFreq + seg.wigglePhase) * seg.wiggleAmp
        -- Secondary sine wave (perpendicular-ish) for 3D motion
        local w2 = math.cos(time * seg.wiggleFreq2 + seg.wigglePhase2) * seg.wiggleAmp2
        
        -- Base position (the aligned position along the rope)
        local basePos = centerPos + seg.baseOffset
        
        -- The wiggle moves the part in a helix/spiral pattern around its base position
        -- Use the segment t (0-1 along rope) to create a wave that propagates upward
        local wavePhase = time * 2.0 + seg.segmentIndex * 0.4 + seg.angleOffset
        
        -- Horizontal wiggle (circular/tornado-like)
        local wiggleX = math.sin(wavePhase) * (seg.wiggleAmp * 0.6 + w1 * 0.3)
        local wiggleZ = math.cos(wavePhase * 0.7 + 1.2) * (seg.wiggleAmp * 0.6 + w2 * 0.3)
        
        -- Vertical wave (makes the rope look like it's snaking up and down)
        local wiggleY = math.sin(time * 1.2 + seg.segmentIndex * 0.5 + seg.angleOffset) * 3
        
        local targetPos = basePos + Vector3.new(wiggleX, wiggleY, wiggleZ)
        
        -- ALIGNMENT: if this part has a part below it in the rope, maintain spacing
        if seg.prevPart and seg.prevPart.Parent then
            local belowPos = seg.prevPart.Position
            local desiredDir = (targetPos - belowPos)
            local desiredDist = seg.spacing * 1.2
            if desiredDir.Magnitude > 0.1 then
                local dir = desiredDir.Unit
                -- Pull toward aligned position relative to the part below
                local alignedPos = belowPos + dir * desiredDist
                -- Blend between wiggle target and alignment target (70% wiggle, 30% alignment)
                targetPos = targetPos * 0.7 + alignedPos * 0.3
            end
        end
        
        -- Also rotate around center for the tornado spin effect
        local toCenter = (basePos - centerPos)
        local horiz = Vector3.new(toCenter.X, 0, toCenter.Z)
        if horiz.Magnitude > 0.5 then
            local perp = Vector3.new(-horiz.Z, 0, horiz.X).Unit
            local spinAmount = math.sin(time * seg.wiggleFreq * 0.5 + seg.angleOffset) * seg.wiggleAmp * 0.8
            targetPos = targetPos + perp * spinAmount
        end
        
        -- Compute velocity toward target
        local vel = (targetPos - p.Position) / math.max(delta, 0.016)
        local maxVel = 200 + seg.wiggleAmp * 4
        if vel.Magnitude > maxVel then vel = vel.Unit * maxVel end
        
        local smoothFactor = math.min(1, delta * 6)
        p.AssemblyLinearVelocity = p.AssemblyLinearVelocity:Lerp(vel, smoothFactor)
        p.CanCollide = false
        
        if p.Position.Y >= (centerPos.Y + funnelHeight) then snapPartDown(p, centerPos.Y) end
    end
end

-- ========== PATH TYPE MOVEMENT ==========
local function pickNewRandomTarget()
    if not localPlayer.Character or not localPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local playerPos = localPlayer.Character.HumanoidRootPart.Position
    local angle = math.random() * math.pi * 2
    -- Use maxRandomRange for the distance cap
    local dist = math.random(50, maxRandomRange)
    randomPathTarget = playerPos + Vector3.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
    randomPathSwitchTimer = tick() + math.random(5, 20)
end

local function pickNewStalkTarget()
    local nonLocal = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= localPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then table.insert(nonLocal, plr) end
    end
    stalkTarget = #nonLocal > 0 and nonLocal[math.random(1, #nonLocal)] or nil
end

local function updateTornadoPositions()
    tornadoPositions = {}
    local root = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local basePos = root.Position; local count = math.max(1, tornadoAmount)
    if count == 1 then
        if pathType == "Follow" then tornadoPositions[1] = basePos
        elseif pathType == "Random" then
            if not randomPathTarget or tick() > randomPathSwitchTimer then pickNewRandomTarget() end
            if randomPathTarget then
                local current = tornadoPositions[1] or basePos; local dir = randomPathTarget - current
                if dir.Magnitude > tornadoRandomPathSpeed * 0.1 then tornadoPositions[1] = current + dir.Unit * math.min(dir.Magnitude, tornadoRandomPathSpeed * 0.1)
                else pickNewRandomTarget(); tornadoPositions[1] = current end
                -- Use maxRandomRange for distance clamp
                if (tornadoPositions[1] - basePos).Magnitude > maxRandomRange then
                    tornadoPositions[1] = tornadoPositions[1] + (basePos - tornadoPositions[1]).Unit * ((tornadoPositions[1] - basePos).Magnitude - maxRandomRange + 10)
                end
            else tornadoPositions[1] = basePos end
        elseif pathType == "Stalker" then
            if not stalkTarget or not stalkTarget.Character or not stalkTarget.Character:FindFirstChild("HumanoidRootPart") then pickNewStalkTarget() end
            if math.random() < 0.01 then pickNewStalkTarget() end
            if stalkTarget and stalkTarget.Character and stalkTarget.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = stalkTarget.Character.HumanoidRootPart.Position; local current = tornadoPositions[1] or basePos; local dir = targetPos - current
                if dir.Magnitude > tornadoMoveSpeed * 0.1 then tornadoPositions[1] = current + dir.Unit * math.min(dir.Magnitude, tornadoMoveSpeed * 0.1)
                else tornadoPositions[1] = targetPos end
                tornadoPositions[1] = tornadoPositions[1] + Vector3.new(0, 5, 0)
            else tornadoPositions[1] = basePos end
        end
    else
        local center = basePos
        if pathType == "Stalker" and stalkTarget and stalkTarget.Character and stalkTarget.Character:FindFirstChild("HumanoidRootPart") then center = stalkTarget.Character.HumanoidRootPart.Position
        elseif pathType == "Random" and randomPathTarget then center = randomPathTarget end
        local time = tick() * 0.15
        for i = 1, count do
            local angle = (i - 1) * (2 * math.pi / count) + time; local spread = math.clamp(tornadoWindfield * 0.12 * math.sqrt(count), 10, tornadoWindfield * 0.35)
            tornadoPositions[i] = center + Vector3.new(math.cos(angle) * spread, 0, math.sin(angle) * spread)
        end
        if pathType == "Random" then
            if not randomPathTarget or tick() > randomPathSwitchTimer then pickNewRandomTarget() end
            if randomPathTarget then local dir = randomPathTarget - (tornadoPositions[1] or center)
                if dir.Magnitude > 1 then for i = 1, count do local offset = tornadoPositions[i] - (tornadoPositions[1] or center); tornadoPositions[i] = tornadoPositions[i] + dir.Unit * math.min(dir.Magnitude, tornadoRandomPathSpeed * 0.1) end end end
        end
    end
end

-- ========== NIGHTMARE MODE — MORE DIRECT TARGETING ==========
local function checkStalkerFling()
    if pathType ~= "Stalker" or not nightmareMode then return end
    if not stalkTarget or not stalkTarget.Character or not stalkTarget.Character:FindFirstChild("HumanoidRootPart") then return end
    if #tornadoPositions == 0 then return end
    local hrp = stalkTarget.Character.HumanoidRootPart; local stalkerPos = hrp.Position
    
    -- NIGHTMARE MODE: More direct targeting - wider detection range, stronger pull
    local detectionRange = nightmareMode and tornadoWindfield * 0.5 or tornadoWindfield * 0.3
    
    for _, pos in ipairs(tornadoPositions) do
        local dist = (stalkerPos - pos).Magnitude
        if dist <= detectionRange then
            -- Nightmare: direct aggressive fling
            local offset = stalkerPos - pos
            local horizontalOffset = Vector3.new(offset.X, 0, offset.Z)
            local distance = math.max(0.1, horizontalOffset.Magnitude)
            local dirToCenter = horizontalOffset.Unit
            local spinDir = Vector3.new(-dirToCenter.Z, 0, dirToCenter.X)
            
            -- NIGHTMARE: higher multipliers, direct toward center, stronger upward
            local spinMultiplier = nightmareMode and 3.5 or 2.5
            local pullMultiplier = nightmareMode and 2.5 or 1.5
            local upMultiplier = nightmareMode and 5 or 3
            
            hrp.AssemblyLinearVelocity = spinDir * (tornadoSpinSpeed * spinMultiplier) 
                + dirToCenter * (tornadoSpinSpeed * pullMultiplier) 
                + Vector3.new(0, tornadoUpwardSpeed * upMultiplier, 0)
            
            -- Also pull nearby parts toward the target for more chaos
            if nightmareMode then
                local nearby = Workspace:GetPartBoundsInRadius(stalkerPos, 30)
                for _, nearPart in ipairs(nearby) do
                    if nearPart:IsA("BasePart") and not nearPart.Anchored and nearPart ~= hrp and not isPlayerPart(nearPart) then
                        local dirToStalker = (stalkerPos - nearPart.Position).Unit
                        nearPart.AssemblyLinearVelocity = dirToStalker * 200 + Vector3.new(0, 100, 0)
                    end
                end
            end
            
            break
        elseif dist <= tornadoWindfield * 0.8 and nightmareMode then
            -- Nightmare: even at medium range, apply some suction force toward center
            local dirToCenter = (pos - stalkerPos).Unit
            local pullStrength = tornadoSpinSpeed * 0.5 * (1 - dist / (tornadoWindfield * 0.8))
            hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity + dirToCenter * pullStrength
        end
    end
end

local function tornadoLoop()
    while enabled do
        updateTornadoPositions()
        if #tornadoPositions > 0 then
            if tornadoType == "Rope" then updateRopeTornado(0.1)
            else updateMainFunnel(0.1); for _, pos in ipairs(tornadoPositions) do applyTornadoPhysics(pos, 0.1) end end
            checkStalkerFling()
        end
        task.wait(0.1)
    end
end

-- ========== SATELLITE SYSTEM ==========
local function createSatelliteMarker(sat)
    if sat.marker and sat.marker.Parent then return end
    local m = Instance.new("Part"); m.Name = "SatelliteMarker"; m.Size = Vector3.new(1,1,1); m.Anchored = true; m.CanCollide = false; m.Material = Enum.Material.Neon; m.Transparency = 0; m.Parent = Workspace; sat.marker = m
end
local function removeSatelliteMarker(sat)
    if sat and sat.marker and sat.marker.Parent then pcall(function() sat.marker:Destroy() end); sat.marker = nil end
end

local function spawnSatelliteWithParts(pos, partsList, idOverride)
    local id = idOverride or nextSatelliteId; if not idOverride then nextSatelliteId = nextSatelliteId + 1 end
    local partsMap = {}
    for _, p in ipairs(partsList) do
        if p and p.Parent then
            local radius = subVortexWidth * (0.3 + math.random() * 0.7); local speed = subVortexSpinSpeed * (1 + (math.random()*0.6 - 0.3))
            partsMap[p] = {radius=radius, speed=speed, phase=math.random()*math.pi*2, floorOffset=2+math.random()*2, topOffset=subVortexHeight+math.random()*4, verticalTarget=nil, currentY=nil}
            assignedToSatellite[p] = id
        end
    end
    satelliteVortices[id] = {id=id, pos=pos, angleOffset=0, parts=partsMap, target=nil, verticalChains={}, lastVortexSpawnTick=tick(), marker=nil}
    satelliteAttackState[id] = {attackingPlayers={}, attackThreads={}}
    local partCount = 0; for _,_ in pairs(partsMap) do partCount = partCount + 1 end
    if partCount == 0 then createSatelliteMarker(satelliteVortices[id]) end
    return id
end

local function despawnSatellite(id)
    local sat = satelliteVortices[id]; if not sat then return end
    for part, _ in pairs(sat.parts) do if part and part.Parent then assignedToSatellite[part] = nil; whitelistedParts[part] = true; pickedUpByFunnel[part] = true; part.CanCollide = true end end
    removeSatelliteMarker(sat); satelliteVortices[id] = nil; satelliteAttackState[id] = nil; noodlePools[id] = nil
end

local function formSatellitesInstant()
    if tornadoType == "Rope" then for id, _ in pairs(satelliteVortices) do despawnSatellite(id) end; spawnRopeTornado(); return end
    for id, _ in pairs(satelliteVortices) do despawnSatellite(id) end
    local count = math.max(0, maxSubVortices); if count == 0 then return end
    local spawnCenter = tornadoPositions[1] or (localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") and localPlayer.Character.HumanoidRootPart.Position) or Vector3.new(0,10,0)
    local allParts = Workspace:GetPartBoundsInRadius(spawnCenter, tornadoWindfield)
    local candidateParts = {}
    for _, p in ipairs(allParts) do 
        if p and p:IsA("BasePart") and not p.Anchored and not isPlayerPart(p) and p.Name ~= baseplateName and not assignedToSatellite[p] and not noodlePartSet[p] and not mainFunnelSet[p] and not ropeParts[p] then
            -- Skip tethered parts
            if not isPartTetheredToAnchored(p) then
                table.insert(candidateParts, p)
            end
        end 
    end
    local total = #candidateParts; table.sort(candidateParts, function(a,b) return (a.Position - spawnCenter).Magnitude < (b.Position - spawnCenter).Magnitude end)
    local desiredByShare = math.floor(total * mainFunnelShare + 0.5); local mainReserve = math.clamp(desiredByShare, 0, total)
    local remainingCount = total - mainReserve
    while remainingCount < count and mainReserve > math.min(funnelReserveCount, total) do mainReserve = mainReserve - 1; remainingCount = total - mainReserve end
    mainReserve = math.clamp(mainReserve, 0, total)
    mainFunnelParts = {}; mainFunnelSet = {}
    for i = 1, mainReserve do local p = candidateParts[i]; if p then mainFunnelParts[#mainFunnelParts+1] = p; mainFunnelSet[p] = true; assignedToSatellite[p] = nil; whitelistedParts[p] = nil; pickedUpByFunnel[p] = nil end end
    local remainingParts = {}; for i = mainReserve + 1, #candidateParts do remainingParts[#remainingParts+1] = candidateParts[i] end
    local partitions = {}; for i = 1, count do partitions[i] = {} end
    if #remainingParts > 0 then local idx = 1; for _, p in ipairs(remainingParts) do local slot = ((idx - 1) % count) + 1; table.insert(partitions[slot], p); assignedToSatellite[p] = true; whitelistedParts[p] = nil; pickedUpByFunnel[p] = nil; idx = idx + 1 end end
    local orbitRad = subVortexWidth * 0.5
    for i = 1, count do local angle = (2 * math.pi * (i - 1) / count); local pos = spawnCenter + Vector3.new(math.cos(angle) * orbitRad, 10 + math.random()*6, math.sin(angle) * orbitRad); spawnSatelliteWithParts(pos, partitions[i] or {}); local newId = nextSatelliteId - 1; if satelliteVortices[newId] then satelliteVortices[newId].angleOffset = angle end end
end

local function updateSatellites(delta)
    if tornadoType == "Rope" or #tornadoPositions == 0 then return end
    local centerPos = tornadoPositions[1]
    for id, sat in pairs(satelliteVortices) do
        sat.angleOffset = sat.angleOffset + (0.5 * delta)
        local orbitRad = math.clamp(subVortexWidth * 0.3, 6, subVortexWidth)
        local newPos = centerPos + Vector3.new(math.cos(sat.angleOffset) * orbitRad, 10, math.sin(sat.angleOffset) * orbitRad)
        local dir = (newPos - sat.pos); sat.pos = sat.pos + dir * math.min(1, delta * 2)
        if sat.marker then pcall(function() sat.marker.CFrame = CFrame.new(sat.pos + Vector3.new(0,2,0)) end) end
        for part, meta in pairs(sat.parts) do
            if part and part.Parent then
                -- Skip if part became tethered mid-flight
                if isPartTetheredToAnchored(part) then
                    sat.parts[part] = nil
                    assignedToSatellite[part] = nil
                    continue
                end
                local angle = (tick() * meta.speed) + meta.phase; local radiusPulse = meta.radius * (1 + 0.06 * math.sin(tick() * 0.5 + meta.phase))
                local horizTarget = sat.pos + Vector3.new(math.cos(angle) * radiusPulse, 0, math.sin(angle) * radiusPulse)
                local floorY = centerPos.Y + (meta.floorOffset or 2); local topY = centerPos.Y + (meta.topOffset or subVortexHeight)
                if not meta.currentY then meta.currentY = math.clamp(part.Position.Y, floorY, topY) end
                if not meta.verticalTarget then meta.verticalTarget = (floorY + topY) / 2 end
                if math.abs(meta.currentY - meta.verticalTarget) < 0.5 then meta.verticalTarget = floorY + math.random() * (math.max(1, topY - floorY)) end
                local interpSpeed = math.max(0.15, (meta.speed or 1) * 0.25); meta.currentY = meta.currentY + (meta.verticalTarget - meta.currentY) * math.clamp(delta * interpSpeed, 0, 1)
                local targetPos = Vector3.new(horizTarget.X, meta.currentY, horizTarget.Z)
                if not part.Anchored then
                    local desiredVel = (targetPos - part.Position) / math.max(delta, 0.016)
                    local maxVel = math.max(orbitVelocityMinCap, math.abs(radiusPulse * meta.speed * orbitVelocityMultiplier))
                    if desiredVel.Magnitude > maxVel then desiredVel = desiredVel.Unit * maxVel end
                    local smoothFactor = math.min(1, delta * 8)
                    part.AssemblyLinearVelocity = part.AssemblyLinearVelocity:Lerp(Vector3.new(desiredVel.X, math.clamp(desiredVel.Y, -140, 140), desiredVel.Z), smoothFactor)
                    part.CanCollide = false
                end
                if part.Position.Y >= (centerPos.Y + funnelHeight) and not debrisAttachedToPlayer[part] then snapPartDown(part, centerPos.Y) end
            else sat.parts[part] = nil end
        end
    end
end

-- ========== FREEZE/UNFREEZE ==========
local function toggleFreeze()
    partsFrozen = not partsFrozen
    freezeBtn.Text = partsFrozen and "Unfreeze" or "Freeze"
    freezeBtn.BackgroundColor3 = partsFrozen and Color3.fromRGB(100, 80, 40) or Color3.fromRGB(60, 60, 70)

    if partsFrozen then
        -- Anchor all affected parts
        frozenParts = {}
        for part in pairs(whitelistedParts) do if part and part.Parent then frozenParts[part] = part.Anchored; part.Anchored = true end end
        for part in pairs(mainFunnelParts) do if part and part.Parent then frozenParts[part] = part.Anchored; part.Anchored = true end end
        for part in pairs(ropeParts) do if part and part.Parent then frozenParts[part] = part.Anchored; part.Anchored = true end end
        for _, sat in pairs(satelliteVortices) do for part, _ in pairs(sat.parts) do if part and part.Parent then frozenParts[part] = part.Anchored; part.Anchored = true end end end
    else
        -- Unanchor all
        for part, wasAnchored in pairs(frozenParts) do
            if part and part.Parent then
                part.Anchored = wasAnchored
            end
        end
        frozenParts = {}
    end
end

