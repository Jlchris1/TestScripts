-- ========== HELPER: Check if a part is connected (welded/constrained) to an anchored part ==========
local function isConnectedToAnchored(part)
    -- Check WeldConstraints
    for _, constraint in ipairs(part:GetConstraints()) do
        if constraint:IsA("WeldConstraint") then
            local other = constraint.Part0 == part and constraint.Part1 or (constraint.Part1 == part and constraint.Part0)
            if other and other:IsA("BasePart") and other.Anchored then
                return true
            end
        end
    end
    -- Check old Weld objects (JointInstance)
    for _, joint in ipairs(part:GetJoints()) do
        if joint:IsA("Weld") or joint:IsA("Snap") then
            local other = joint.Part0 == part and joint.Part1 or (joint.Part1 == part and joint.Part0)
            if other and other:IsA("BasePart") and other.Anchored then
                return true
            end
        end
    end
    -- Check ManualWeld/SurfaceWeld
    for _, weld in ipairs(part:GetChildren()) do
        if (weld:IsA("Weld") or weld:IsA("ManualWeld") or weld:IsA("SurfaceWeld")) then
            local other = weld.Part0 == part and weld.Part1 or (weld.Part1 == part and weld.Part0)
            if other and other:IsA("BasePart") and other.Anchored then
                return true
            end
        end
    end
    -- Also check if the part is itself welded to something that ultimately chains to an anchored part
    -- We do a simple one-hop check: if any neighbor via attachment/constraint is anchored
    for _, att in ipairs(part:GetAttachments()) do
        for _, c in ipairs(att:GetConnectedParts(true)) do
            if c ~= part and c:IsA("BasePart") and c.Anchored then
                return true
            end
        end
    end
    return false
end

