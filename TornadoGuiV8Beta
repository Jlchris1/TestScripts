-- ========== WORKSPACE SCANNING ==========
Workspace.DescendantAdded:Connect(function(desc)
    if desc and desc:IsA("BasePart") then
        task.defer(function() if enabled then for _, pos in ipairs(tornadoPositions) do if (desc.Position - pos).Magnitude <= tornadoWindfield then if not desc.Anchored and not isPartTetheredToAnchored(desc) then processPartForFunnel(desc) end; break end end end end)
    end
end)

spawn(function()
    while true do
        if enabled and #tornadoPositions > 0 then
            for _, pos in ipairs(tornadoPositions) do
                local parts = Workspace:GetPartBoundsInRadius(pos, tornadoWindfield)
                for _, p in ipairs(parts) do if p and p:IsA("BasePart") and not p.Anchored then processPartForFunnel(p) end end
            end
            if tornadoType ~= "Rope" then reserveMainFunnelParts() end
        end; task.wait(1) end
end)

RunService.Heartbeat:Connect(function(delta)
    if enabled then
        updateTornadoPositions()
        if tornadoType == "Classic" then updateSatellites(delta); updateMainFunnel(delta)
        elseif tornadoType == "Rope" then updateRopeTornado(delta) end
    end
end)

local function onCharacterAdded(character)
    task.wait(0.1)
    if character:FindFirstChild("HumanoidRootPart") then updateTornadoPositions() end
    if enabled then
        if tornadoType == "Rope" then spawnRopeTornado() else formSatellitesInstant() end
    end
end
if localPlayer.Character then onCharacterAdded(localPlayer.Character) end
localPlayer.CharacterAdded:Connect(onCharacterAdded)

toggleBtn.MouseButton1Click:Connect(function()
    guiVisible = not guiVisible; mainFrame.Visible = guiVisible
end)

startStopBtn.MouseButton1Click:Connect(function()
    enabled = not enabled
    startStopBtn.Text = enabled and "Stop" or "Start"
    startStopBtn.BackgroundColor3 = enabled and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(50, 120, 50)
    statusDot.BackgroundColor3 = enabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(180, 40, 40)
    if enabled then
        pickedUpByFunnel = {}; whitelistedParts = {}; assignedToSatellite = {}
        satelliteVortices = {}; satelliteAttackState = {}; nextSatelliteId = 1
        debrisAttachedToPlayer = {}; noodlePools = {}; noodlePartSet = {}
        mainFunnelParts = {}; mainFunnelSet = {}; ropeParts = {}; ropeSegments = {}
        randomPathTarget = nil; stalkTarget = nil
        updateTornadoPositions()
        if #tornadoPositions > 0 then
            for _, pos in ipairs(tornadoPositions) do
                local parts = Workspace:GetPartBoundsInRadius(pos, tornadoWindfield)
                for _, p in ipairs(parts) do if p and p:IsA("BasePart") and not p.Anchored then processPartForFunnel(p) end end
            end
            if tornadoType == "Rope" then spawnRopeTornado() else reserveMainFunnelParts(); formSatellitesInstant() end
        end
        spawn(tornadoLoop)
    else
        -- If frozen, unfreeze first
        if partsFrozen then toggleFreeze() end
        for part in pairs(whitelistedParts) do if part and part:IsA("BasePart") and part.Parent then pcall(function() part.AssemblyLinearVelocity = Vector3.zero end); part.CanCollide = true end end
        for id, _ in pairs(satelliteVortices) do despawnSatellite(id) end
        for part in pairs(ropeParts) do if part and part.Parent then part.AssemblyLinearVelocity = Vector3.zero; part.CanCollide = true end end
        ropeParts = {}; ropeSegments = {}; debrisAttachedToPlayer = {}; whitelistedParts = {}; pickedUpByFunnel = {}
        assignedToSatellite = {}; satelliteVortices = {}; satelliteAttackState = {}
        noodlePools = {}; noodlePartSet = {}; mainFunnelParts = {}; mainFunnelSet = {}
        tornadoPositions = {}; randomPathTarget = nil; stalkTarget = nil
    end
end)

