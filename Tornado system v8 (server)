-- Handle SummonTornado fired from client
SummonTornadoEvent.OnServerEvent:Connect(function(player, params)
	pcall(function()
		if not isAllowedToUseCommands(player) then
			warn(("[SummonTornado] %s tried to summon but lacks permission."):format(player.Name)); return
		end
		if not params or type(params) ~= "table" then
			warn("[SummonTornado] invalid params from client."); return
		end
		local spawnX, spawnZ = 0, 0
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local hrp = player.Character.HumanoidRootPart
			spawnX, spawnZ = hrp.Position.X, hrp.Position.Z
		else
			if player.Character and player.Character:FindFirstChild("Head") then
				local head = player.Character.Head
				spawnX, spawnZ = head.Position.X, head.Position.Z
			else
				spawnX, spawnZ = 0, 0
			end
		end

		local fd = tonumber(params.funnelDiameter) or params.funnelDiameter or 300
		local wr = tonumber(params.windfieldRadius) or params.windfieldRadius or math.max(fd + CONFIG.WINDFIELD_BUFFER, fd * 1.2)
		local ws = tonumber(params.windspeedMPH) or params.windspeedMPH or 200
		local ms = tonumber(params.moveSpeed) or params.moveSpeed or 3
		local ls = tonumber(params.lifespan) or params.lifespan or 420

		print(("[Tornado] Summon request from %s -> spawn=(%.1f,%.1f) funnel=%s windfield=%s wind=%s move=%s life=%s")
			:format(player.Name, spawnX, spawnZ, tostring(fd), tostring(wr), tostring(ws), tostring(ms), tostring(ls)))

		task.spawn(function()
			spawnTornadoAt(spawnX, spawnZ, {
				funnelDiameter = fd,
				windfieldRadius = wr,
				windspeedMPH = ws,
				moveSpeed = ms,
				lifespan = ls,
				ownerUserId = player.UserId,
			}, true)
		end)
	end)
end)

-- Handle live param updates from client
UpdateTornadoEvent.OnServerEvent:Connect(function(player, params)
	pcall(function()
		if not isAllowedToUseCommands(player) then return end
		if not params or type(params) ~= "table" then return end
		-- find the newest tornado record that belongs to this player AND still accepts live resize
		local chosen = nil
		local bestTimestamp = 0
		for _, rec in ipairs(activeTornadoes) do
			if rec.ownerUserId == player.UserId and rec.acceptsLiveResize and rec.createdAt and rec.createdAt > bestTimestamp then
				chosen = rec
				bestTimestamp = rec.createdAt
			end
		end
		if not chosen or not chosen.applyParams then return end
		-- apply WITHOUT clamping, but only if chosen.acceptsLiveResize == true (applyParams already checks)
		local newParams = {}
		if params.funnelDiameter then newParams.funnelDiameter = tonumber(params.funnelDiameter) or params.funnelDiameter end
		if params.windspeedMPH then newParams.windspeedMPH = tonumber(params.windspeedMPH) or params.windspeedMPH end
		if params.windfieldRadius then newParams.windfieldRadius = tonumber(params.windfieldRadius) or params.windfieldRadius end
		if params.moveSpeed then newParams.moveSpeed = tonumber(params.moveSpeed) or params.moveSpeed end
		if params.lifespan then newParams.lifespan = tonumber(params.lifespan) or params.lifespan end
		pcall(function() chosen:applyParams(newParams) end)
	end)
end)

