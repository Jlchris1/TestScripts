local function isAllowedToUseCommands(player)
	if CONFIG.COMMAND_ACCESS == "Everyone" then return true end
	if CONFIG.COMMAND_ACCESS == "OwnerOnly" then
		if player.UserId == CONFIG.OWNER_USERID then return true end
		for _, id in ipairs(CONFIG.OWNER_FRIEND_IDS) do
			if player.UserId == id then return true end
		end
		return false
	end
	if CONFIG.COMMAND_ACCESS == "OwnerFriends" then
		if player.UserId == CONFIG.OWNER_USERID then return true end
		for _, id in ipairs(CONFIG.OWNER_FRIEND_IDS) do if player.UserId == id then return true end end
		return false
	end
	return false
end

local function clearAllTornadoes(requester)
	for i = #activeTornadoes, 1, -1 do
		local rec = activeTornadoes[i]
		if rec then
			pcall(function() cleanupTornadoRecord(rec) end)
		end
	end
	print(("[Cmd] %s cleared all tornadoes."):format(requester and requester.Name or "Server"))
end

