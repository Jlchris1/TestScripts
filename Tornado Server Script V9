-- permission check helper
local function isAllowedToUseCommands(player)
	if CONFIG.COMMAND_ACCESS == "Everyone" then return true end
	if CONFIG.COMMAND_ACCESS == "OwnerOnly" then return player.UserId == CONFIG.OWNER_USERID end
	if CONFIG.COMMAND_ACCESS == "OwnerFriends" then
		if player.UserId == CONFIG.OWNER_USERID then return true end
		for _, id in ipairs(CONFIG.OWNER_FRIEND_IDS) do if player.UserId == id then return true end end
		return false
	end
	return false
end

-- Chat command: server listens and tells client to open GUI
Players.PlayerAdded:Connect(function(pl)
	pl.Chatted:Connect(function(msg)
		pcall(function()
			local cmd = type(msg)=="string" and msg:lower():gsub("^%s+", ""):gsub("%s+$", "") or ""
			if cmd == "/summon tornado" then
				if not isAllowedToUseCommands(pl) then
					warn(("[Cmd] %s tried to spawn tornado but lacks permission."):format(pl.Name))
