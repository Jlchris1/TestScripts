-- Handle SummonTornado fired from client (client sends numeric params)
SummonTornadoEvent.OnServerEvent:Connect(function(player, params)
	pcall(function()
		if not isAllowedToUseCommands(player) then
			warn(("[SummonTornado] %s tried to summon but lacks permission."):format(player.Name)); return
		end
		if not params or type(params) ~= "table" then
			warn("[SummonTornado] invalid params from client."); return
		end
		-- Get spawn position from player's HRP (server-side)
		local spawnX, spawnZ = 0, 0
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local hrp = player.Character.HumanoidRootPart
			spawnX, spawnZ = hrp.Position.X, hrp.Position.Z
		else
			-- fallback: try head or 0,0
			if player.Character and player.Character:FindFirstChild("Head") then
				local head = player.Character.Head
				spawnX, spawnZ = head.Position.X, head.Position.Z
			else
				spawnX, spawnZ = 0, 0
			end
		end

		-- IMPORTANT: per admin request, we accept the raw numeric values (server is authoritative for behavior but does not clamp admin's requested numbers).
		local fd = tonumber(params.funnelDiameter) or params.funnelDiameter or 300
		local wr = tonumber(params.windfieldRadius) or params.windfieldRadius or math.max(fd + CONFIG.WINDFIELD_BUFFER, fd * 1.2)
		local ws = tonumber(params.windspeedMPH) or params.windspeedMPH or 200
		local ms = tonumber(params.moveSpeed) or params.moveSpeed or 3
		local ls = tonumber(params.lifespan) or params.lifespan or 420

		print(("[Tornado] Summon request from %s -> spawn=(%.1f,%.1f) funnel=%s windfield=%s wind=%s move=%s life=%s")
			:format(player.Name, spawnX, spawnZ, tostring(fd), tostring(wr), tostring(ws), tostring(ms), tostring(ls)))

		-- Spawn tornado (server authoritative). immediateFormation true to skip long cloud-delay
		task.spawn(function()
			spawnTornadoAt(spawnX, spawnZ, {
				funnelDiameter = fd,
				windfieldRadius = wr,
				windspeedMPH = ws,
				moveSpeed = ms,
				lifespan = ls,
				ownerUserId = player.UserId,
			}, true)
		end)
	end)
end)

