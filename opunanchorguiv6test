local function isNPC(character)
    if not character or not character:IsA("Model") then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid and not Players:GetPlayerFromCharacter(character) then return true end
    return false
end

local function isPartPlayerCharacter(part)
    if not part then return false end
    for _, pl in ipairs(Players:GetPlayers()) do
        local char = pl.Character
        if char and part:IsDescendantOf(char) then
            return true
        end
    end
    return false
end

local function isScriptOwned(instance)
    for _, owned in ipairs(scriptOwnedInstances) do
        if owned == instance then return true end
    end
    return false
end

local function markScriptOwned(instance)
    table.insert(scriptOwnedInstances, instance)
end

-- Optimized stripBodyForces - only runs when necessary
local function stripBodyForces(part)
    -- Only strip non-script-owned items on first processing
    for _, x in next, part:GetChildren() do
        if x:IsA("Attachment") or x:IsA("AlignPosition") or x:IsA("Torque") or x:IsA("BodyAngularVelocity") 
           or x:IsA("BodyForce") or x:IsA("BodyGyro") or x:IsA("BodyPosition") or x:IsA("BodyThrust")
           or x:IsA("BodyVelocity") or x:IsA("RocketPropulsion") or x:IsA("Weld") or x:IsA("WeldConstraint") then
            if not isScriptOwned(x) then
                x:Destroy()
            end
        end
    end
end

-- Anti-tamper - lightweight version
local function setupAntiTamper(part)
    if not part or antiTamperConnections[part] then return end
    
    local conns = {}
    
    -- Only monitor child additions (most important for preventing external attachments)
    local childConn = part.ChildAdded:Connect(function(child)
        if not antiTamperActive then return end
        if child:IsA("Attachment") or child:IsA("AlignPosition") or child:IsA("AlignOrientation") 
           or child:IsA("Torque") or child:IsA("AngularVelocity") or child:IsA("VectorForce")
           or child:IsA("BodyMover") or child:IsA("Weld") or child:IsA("WeldConstraint")
           or child:IsA("Snap") or child:IsA("HingeConstraint") then
            if not isScriptOwned(child) then
                pcall(function() child:Destroy() end)
            end
        end
    end)
    table.insert(conns, childConn)
    
    antiTamperConnections[part] = conns
end

local function shuffle(t)
    for i = #t, 2, -1 do
        local j = math.random(1, i)
        t[i], t[j] = t[j], t[i]
    end
end

local function smoothLerpCFrame(curCF, targetCF, dt)
    local alpha = 1 - math.exp(-TARGET_SMOOTHNESS * dt)
    if alpha < 0.001 then alpha = 0.001 end
    if alpha > 0.99 then alpha = 0.99 end
    return curCF:Lerp(targetCF, alpha)
end

