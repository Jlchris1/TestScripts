local function getClientPing()
    local ok, ping = pcall(function()
        if localPlayer and localPlayer.GetNetworkPing then
            return localPlayer:GetNetworkPing()
        end
        return nil
    end)
    if ok and type(ping) == "number" and ping > 0 then
        return ping
    end
