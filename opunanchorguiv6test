local function getRandomValidTarget(excludePlayer)
    local targets = {}
    local players = getAllNonLocalPlayers()
    for _, pl in ipairs(players) do
        if pl ~= excludePlayer and isPlayerAlive(pl) then table.insert(targets, pl) end
    end
    if #targets == 0 then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Parent and isPlayerAlive(p) and p ~= excludePlayer then table.insert(targets, p) end
        end
    end
    if #targets == 0 then return nil end
    return targets[math.random(1, #targets)]
end

local function reassignIndividualPart(part)
    local data = individualPartsData[part]
    if not data then return end
    local newPlayer
    if math.random() < 0.7 then
        newPlayer = getRandomValidTarget(data.targetPlayer)
        if not newPlayer then newPlayer = getRandomValidTarget(nil) end
    else
        newPlayer = data.targetPlayer
        if not newPlayer or not isPlayerAlive(newPlayer) then newPlayer = getRandomValidTarget(nil) end
    end
    if not newPlayer then return end
    data.targetPlayer = newPlayer
    if data.targetPart and data.targetPart.Parent then pcall(function() data.targetPart:Destroy() end) end
    local targetPart, targetAtt = createIndividualTargetAttachment(newPlayer, part)
    if targetPart and targetAtt then
        data.targetPart = targetPart
        data.targetAttachment = targetAtt
        if data.alignPos then pcall(function() data.alignPos.Attachment1 = targetAtt end) end
    end
    data.phase = math.random() * math.pi * 2
    data.orbitRadius = INDIVIDUAL_ORBIT_RADIUS_BASE + (math.random() * INDIVIDUAL_ORBIT_RADIUS_VARY)
    data.orbitSpeed = INDIVIDUAL_ORBIT_SPEED + (math.random() * 1.5)
    data.verticalAmp = INDIVIDUAL_VERTICAL_OSCILLATION * (0.5 + math.random())
end

local function startIndividualPartThread(part, data)
    data.thread = spawn(function()
        local timeAccum = 0
        while individualPartsActive and part and part.Parent and data and data.active do
            local dt = RunService.Heartbeat:Wait()
            if not dt then dt = 0.016 end
            timeAccum = timeAccum + dt
            local player = data.targetPlayer
            if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and isPlayerAlive(player) then
                local hrp = player.Character.HumanoidRootPart
                local pos = hrp.Position
                local vel = hrp.Velocity or Vector3.new(0,0,0)
                local speed = vel.Magnitude
                local dir = (speed > 1) and vel.Unit or hrp.CFrame.LookVector
                local predictedPos = predictTargetPosition(player, pos, vel, tick())
                local phase = data.phase + timeAccum * data.orbitSpeed
                local radius = data.orbitRadius * (1 + 0.3 * math.sin(timeAccum * 0.7 + data.phase))
                local orbitX = math.cos(phase) * radius
                local orbitZ = math.sin(phase * 0.8) * radius * 0.7
                local verticalOffset = math.sin(timeAccum * 1.3 + data.phase * 1.7) * data.verticalAmp
                local chaosFactor = clamp(speed * 0.1, 0, 3)
                local chaosX = math.sin(timeAccum * 2.1 + data.phase) * chaosFactor
                local chaosZ = math.cos(timeAccum * 1.9 + data.phase * 1.3) * chaosFactor
                local chaosY = math.sin(timeAccum * 2.7 + data.phase * 2.3) * chaosFactor * 0.5
                local offset = Vector3.new(orbitX + chaosX, verticalOffset + chaosY, orbitZ + chaosZ)
                if speed > 5 then offset = offset + (-dir * clamp(speed * 0.08, 0, 3)) end
                local targetPos = predictedPos + offset
                if data.targetPart and data.targetPart.Parent then
                    local curPos = data.targetPart.Position
                    local smoothPos = curPos + (targetPos - curPos) * clamp(dt * 12, 0, 0.5)
                    data.targetPart.Position = smoothPos
                    if speed > 0.5 then pcall(function() data.targetPart.CFrame = CFrame.lookAt(smoothPos, smoothPos + vel) end) end
                end
            else
                if not data.switchingLock then
                    data.switchingLock = true
                    spawn(function()
                        wait(0.1)
                        pcall(function() if data and individualPartsActive then reassignIndividualPart(part) end end)
                        if data then data.switchingLock = false end
                    end)
                end
            end
            if data.nextSwitchTime and timeAccum >= data.nextSwitchTime then
                if not data.switchingLock then
                    data.switchingLock = true
                    spawn(function()
                        wait(0.05)
                        if data and individualPartsActive then pcall(function() reassignIndividualPart(part) end) end
                        if data then
                            data.switchingLock = false
                            data.nextSwitchTime = timeAccum + INDIVIDUAL_SWITCH_INTERVAL_BASE + (math.random() * INDIVIDUAL_SWITCH_INTERVAL_VARY)
                        end
                    end)
                end
            end
        end
        if data then data.thread = nil end
    end)
end

local function ForcePartIndividual(v)
    if not v or not v:IsA("BasePart") then return end
    if isPartPlayerCharacter(v) then return end
    if localPlayer.Character and v:IsDescendantOf(localPlayer.Character) then return end
    if v:IsA("BasePart") and not v.Anchored and v.Name ~= "Handle"
        and ((v.Parent:FindFirstChildOfClass("Humanoid") and isNPC(v.Parent)) or (not v.Parent:FindFirstChildOfClass("Humanoid") and not v.Parent:FindFirstChild("Head"))) then
        if processedParts[v] then return end
        processedParts[v] = true
        if individualPartsData[v] then return end
        if initiallyMasslessParts[v] == nil then pcall(function() initiallyMasslessParts[v] = v.Massless end) end
        pcall(function() v.Massless = true end)
        stripBodyForces(v)
        v.CanCollide = false
        local partAtt = Instance.new("Attachment", v)
        registerScriptOwned(partAtt)
        pcall(function() partAtt.WorldCFrame = v.CFrame end)
        local alignPos = Instance.new("AlignPosition", v)
        alignPos.Attachment0 = partAtt
        registerScriptOwned(alignPos)
        local ok, isMass = pcall(function() return v.Massless end)
        local maxF = PULL_MAX_FORCE; local resp = PULL_RESPONSIVENESS
        if ok and isMass == true then maxF = maxF * MASSLESS_PULL_SCALE; resp = resp * MASSLESS_RESP_SCALE end
        alignPos.MaxForce = maxF; alignPos.MaxVelocity = math.huge; alignPos.Responsiveness = resp
        local torqueVal = FLING_TORQUE
        if ok and isMass == true then torqueVal = torqueVal * MASSLESS_TORQUE_SCALE end
        local torque = Instance.new("Torque", v)
        torque.Torque = torqueVal; torque.Attachment0 = partAtt
        registerScriptOwned(torque)
        local initialPlayer = getRandomValidTarget(nil)
        if not initialPlayer then alignPos.Attachment1 = Attachment1; return end
        local targetPart, targetAtt = createIndividualTargetAttachment(initialPlayer, v)
        if targetAtt then alignPos.Attachment1 = targetAtt else alignPos.Attachment1 = Attachment1 end
        local data = {
            part = v, attachment = partAtt, alignPos = alignPos, torque = torque,
            targetPlayer = initialPlayer, targetPart = targetPart, targetAttachment = targetAtt,
            phase = math.random() * math.pi * 2,
            orbitRadius = INDIVIDUAL_ORBIT_RADIUS_BASE + (math.random() * INDIVIDUAL_ORBIT_RADIUS_VARY),
            orbitSpeed = INDIVIDUAL_ORBIT_SPEED + (math.random() * 1.5),
            verticalAmp = INDIVIDUAL_VERTICAL_OSCILLATION * (0.5 + math.random()),
            nextSwitchTime = INDIVIDUAL_SWITCH_INTERVAL_BASE + (math.random() * INDIVIDUAL_SWITCH_INTERVAL_VARY),
            active = true, thread = nil, switchingLock = false,
        }
        individualPartsData[v] = data
        startIndividualPartThread(v, data)
    end
end

local function startIndividualParts()
    if individualPartsActive then return end
    individualPartsActive = true
    for _, v in ipairs(Workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") and not v.Anchored and v.Name ~= "Handle" and not isPartPlayerCharacter(v)
                and not (localPlayer.Character and v:IsDescendantOf(localPlayer.Character))
