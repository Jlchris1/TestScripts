end

local function pushVelocitySample(pl, vel, now)
    if not pl then return end
    playerVelBuffer[pl] = playerVelBuffer[pl] or {}
    local buf = playerVelBuffer[pl]
    table.insert(buf, 1, {t = now, v = vel})
    while #buf > 6 do table.remove(buf) end
end

local function estimateAccelFromBuffer(pl)
    local buf = playerVelBuffer[pl]
    if not buf or #buf < 2 then return Vector3.new(0,0,0) end
    local total = Vector3.new(0,0,0)
    local count = 0
    for i = 1, #buf-1 do
        local cur = buf[i].v
        local nxt = buf[i+1].v
        local dt = buf[i].t - buf[i+1].t
        if dt > 0 then
            total = total + (cur - nxt) / dt
            count = count + 1
        end
    end
    if count == 0 then return Vector3.new(0,0,0) end
    return total / count
end

local function predictTargetPosition(pl, pos, vel, now)
    pushVelocitySample(pl, vel, now)
    local accel_est = estimateAccelFromBuffer(pl)
    local ping = getClientPing()
    local baseLead = 0.05
    local effectiveLat = clamp(ping + baseLead, 0.03, 0.45)
    local speed = vel.Magnitude
    local speedFactor = clamp(0.12 + (speed * 0.03), 0.12, 1.4)
    local rotComp = Vector3.new(0,0,0)
    local rotVel = Vector3.new(0,0,0)
    if pl and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = pl.Character.HumanoidRootPart
        local ok, rv = pcall(function() return hrp.RotVelocity end)
        if ok and typeof(rv) == "Vector3" then
            rotVel = rv
        end
    end
    local rotMag = rotVel.Magnitude
    if rotMag > 1 then
        local lateralScale = clamp(rotMag * 0.01 * speed, 0, math.max(0.5, speed * 0.25))
        if speed > 0.001 then
            local perp = Vector3.new(-vel.Z, 0, vel.X).Unit
            if perp then rotComp = perp * lateralScale end
        end
    end
    local leadTime = effectiveLat * speedFactor
    leadTime = clamp(leadTime, 0.03, 0.6)
    local predicted = pos + vel * leadTime + 0.5 * accel_est * (leadTime * leadTime) + rotComp
    return predicted, leadTime, accel_est, ping
end

-- ====== GATHER PARTS SYSTEM (FIXED - single use, teleports to groups) ======

local function findPartGroups()
    -- Find groups of unanchored parts that are closer to other players than to local
    local localChar = localPlayer.Character
    if not localChar or not localChar:FindFirstChild("HumanoidRootPart") then return {} end
    local localPos = localChar.HumanoidRootPart.Position
    
    -- Get other player positions
    local otherPlayers = {}
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= localPlayer and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(otherPlayers, {
                player = pl,
                position = pl.Character.HumanoidRootPart.Position
            })
        end
    end
    
    -- Find all candidate parts
    local allCandidates = {}
    for _, v in ipairs(Workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") and not v.Anchored and v.Name ~= "Handle"
                and not isPartPlayerCharacter(v)
                and not (localChar and v:IsDescendantOf(localChar))
                and v.Transparency < 1 then
                
                local partPos = v.Position
                local distToLocal = (partPos - localPos).Magnitude
                
                -- Check if closer to any other player than to local
                for _, op in ipairs(otherPlayers) do
                    local distToOther = (partPos - op.position).Magnitude
                    if distToOther < distToLocal and distToLocal > 15 then
                        table.insert(allCandidates, {
                            part = v,
                            position = partPos,
                            distance = distToLocal,
                            closestPlayerDist = distToOther
                        })
                        break
                    end
                end
            end
        end)
    end
    
    -- Group by proximity (within 30 studs = same group)
    local groups = {}
    local processed = {}
    
    for i, candidate in ipairs(allCandidates) do
        if not processed[i] then
            local group = {candidate}
            processed[i] = true
            
            for j = i+1, #allCandidates do
                if not processed[j] then
                    local dist = (candidate.position - allCandidates[j].position).Magnitude
                    if dist < 30 then
                        table.insert(group, allCandidates[j])
                        processed[j] = true
                    end
                end
            end
            
            table.insert(groups, group)
        end
    end
    
    -- Sort groups by size (largest first)
    table.sort(groups, function(a, b) return #a > #b end)
    
    return groups
end

local function forceCollectGroup(group)
    -- Teleport to the group center and force collect all parts
    if #group == 0 then return end
    
    -- Calculate group center
    local center = Vector3.new(0, 0, 0)
    for _, item in ipairs(group) do
        center = center + item.position
    end
    center = center / #group
    
    -- Teleport local player to group center
    local char = localPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local hrp = char.HumanoidRootPart
        pcall(function()
            hrp.CFrame = CFrame.new(center + Vector3.new(0, 5, 0))
        end)
    end
    
    -- Force collect each part in the group
    for _, item in ipairs(group) do
        local part = item.part
        if part and part.Parent then
            -- Save original state
            if not gatheredPartsList[part] then
                gatheredPartsList[part] = {
                    originalCF = part.CFrame,
                    originalPos = part.Position,
                    originalAnchored = part.Anchored,
                    originalCanCollide = part.CanCollide
                }
            end
            
            -- Teleport part to local player
            local char = localPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local hrp = char.HumanoidRootPart
                local offset = Vector3.new(
                    math.random(-8, 8),
                    math.random(0, 10),
                    math.random(-8, 8)
                )
                part.CFrame = hrp.CFrame * CFrame.new(offset)
                part.Velocity = Vector3.new(0, 0, 0)
                part.RotVelocity = Vector3.new(0, 0, 0)
            end
        end
    end
end

local function runGatherParts()
    if gatherPartsActive then return end
    gatherPartsActive = true
    antiTamperActive = true
    
    -- Save original position
    local char = localPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        gatherPartsOriginalPos = char.HumanoidRootPart.Position
        gatherPartsOriginalCF = char.HumanoidRootPart.CFrame
    end
    
    gatheredPartsList = {}
    
    -- Single-use: find groups and collect them
    spawn(function()
        local groups = findPartGroups()
        
        if #groups == 0 then
            -- No groups found, try scanning one more time
            wait(0.1)
            groups = findPartGroups()
        end
        
        -- Process each group
        for i, group in ipairs(groups) do
            if not gatherPartsActive then break end
            forceCollectGroup(group)
            wait(0.08) -- Small delay between groups for server to catch up
        end
        
        -- Wait a moment then return to origin
        wait(0.5)
        
        -- Return parts to original positions
        for part, data in pairs(gatheredPartsList) do
            if part and part.Parent then
                local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                local tween = TweenService:Create(part, tweenInfo, {
                    CFrame = data.originalCF,
                    Velocity = Vector3.new(0,0,0),
                    RotVelocity = Vector3.new(0,0,0)
                })
                tween:Play()
                Debris:AddItem(tween, 2)
            end
        end
        
        -- Return local player to original position
        if gatherPartsOriginalCF then
            local char = localPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local hrp = char.HumanoidRootPart
                local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                local tween = TweenService:Create(hrp, tweenInfo, {
                    CFrame = gatherPartsOriginalCF
                })
                tween:Play()
            end
        end
        
        wait(1)
        gatheredPartsList = {}
        gatherPartsOriginalPos = nil
        gatherPartsOriginalCF = nil
        gatherPartsActive = false
        
        if not targetAllActive and not targetSelectedActive and not IndividualPartsEnabled then
            antiTamperActive = false
        end
    end)
end

