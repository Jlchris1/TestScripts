-- ====== LAG MANAGEMENT ======
local lagMonitorRunning = false
local lagSpikeDetected = false
local PERFORMANCE_MODE = false
local lastFrameTime = tick()
local frameTimes = {}

-- Monitor framerate and auto-throttle on lag
local function startLagMonitor()
    if lagMonitorRunning then return end
    lagMonitorRunning = true
    spawn(function()
        while true do
            local now = tick()
            local dt = now - lastFrameTime
            lastFrameTime = now
            table.insert(frameTimes, dt)
            if #frameTimes > 30 then table.remove(frameTimes, 1) end
            
            -- Calculate average FPS over last 30 frames
            local avg = 0
            for _, t in ipairs(frameTimes) do
                avg = avg + t
            end
            avg = avg / #frameTimes
            local fps = avg > 0 and 1 / avg or 60
            
            -- If FPS drops below 15, enable performance mode
            if fps < 15 and not PERFORMANCE_MODE then
                PERFORMANCE_MODE = true
                lagSpikeDetected = true
                -- Throttle everything
                switchDelay = 0.3
                rebalancerFreq = 0.5
                -- Clear some processed parts to reduce load
                local count = 0
                for part, _ in pairs(processedParts) do
                    if count > 50 then break end
                    if part and part.Parent then
                        local ap = part:FindFirstChildOfClass("AlignPosition")
                        if ap then ap.Attachment1 = Attachment1 end
                    end
                    processedParts[part] = nil
                    count = count + 1
                end
            elseif fps > 30 and PERFORMANCE_MODE then
                PERFORMANCE_MODE = false
                lagSpikeDetected = false
                switchDelay = 0.13
                rebalancerFreq = 0.10
            end
            
            wait(1)
        end
    end)
end
startLagMonitor()

-- Throttled workspace scanning - scan in chunks to avoid lag
local function throttledDescendantScan(callback, chunkSize)
    chunkSize = chunkSize or 50
    local allDescendants = Workspace:GetDescendants()
    local index = 1
    local total = #allDescendants
    
    while index <= total do
        local endIdx = math.min(index + chunkSize - 1, total)
        for i = index, endIdx do
            pcall(function() callback(allDescendants[i]) end)
        end
        index = endIdx + 1
        -- Yield between chunks to let other processes run
        if index <= total then
            wait()
        end
        -- Stop if lag spike
        if lagSpikeDetected then
            wait(0.1)
        end
    end
end

-- ====== RESPAWN SAFETY ======
local respawnGuard = false
local respawnTimer = nil

local function onCharacterAdded(newChar)
    -- Wait a bit before re-initializing to let the character load
    wait(1)
    
    character = newChar
    humanoidRootPart = newChar:WaitForChild("HumanoidRootPart", 5)
    
    -- Re-setup attachment if needed
    if not Attachment1 or not Attachment1.Parent then
        Attachment1 = setupPlayer()
    end
    
    -- If BH modes were active, restart them after respawn
    if targetAllActive or targetSelectedActive then
        processedParts = {}
        wait(0.5)
        startPrimaryLoop()
    end
    
    if IndividualPartsEnabled then
        processedParts = {}
        wait(0.5)
        startIndividualParts()
    end
    
    respawnGuard = false
end

-- Handle respawn safely
localPlayer.CharacterAdded:Connect(function(newChar)
    -- Clear processed parts to prevent stale references
    respawnGuard = true
    processedParts = {}
    individualPartsData = {}
    gatheredPartsList = {}
    
    -- Stop heavy processes
    if gatherPartsActive then
        gatherPartsActive = false
        if gatherPartsHeartbeat then
            gatherPartsHeartbeat:Disconnect()
            gatherPartsHeartbeat = nil
        end
    end
    
    -- Delayed re-init
    if respawnTimer then
        respawnTimer:Cancel()
    end
    spawn(function()
        wait(1.5)
        onCharacterAdded(newChar)
    end)
end)

