    angVel.AngularVelocity = Vector3.new(
        math.random(-100, 100),
        math.random(-100, 100),
        math.random(-100, 100)
    ) * 10
    angVel.MaxTorque = Vector3.new(1000000, 1000000, 1000000)
    markScriptOwned(angVel)
end

