local function clamp(val, a, b)
    if val < a then return a end
    if val > b then return b end
    return val
end

-- ====== ANTI-TAMPER SYSTEM ======
-- Nullifies property changes / instances not originating from this script
local antiTamperRunning = false
local scriptOwnedParts = {}
local scriptOwnedInstances = {}
local scriptAttachments = {}
local scriptAlignPositions = {}
local scriptTorques = {}
local scriptWelds = {}
local scriptParts = {}

local function isScriptOwned(obj)
    if not obj then return false end
    if scriptOwnedParts[obj] or scriptOwnedInstances[obj] or scriptAttachments[obj] or scriptAlignPositions[obj] or scriptTorques[obj] or scriptWelds[obj] or scriptParts[obj] then
        return true
    end
    local bhFolder = Workspace:FindFirstChild("ÆS_BlackHole_Folder")
    local indFolder = Workspace:FindFirstChild("ÆS_IndividualParts_Folder")
    local gatherFolder = Workspace:FindFirstChild("ÆS_GatherParts_Folder")
    if bhFolder and obj:IsDescendantOf(bhFolder) then return true end
    if indFolder and obj:IsDescendantOf(indFolder) then return true end
    if gatherFolder and obj:IsDescendantOf(gatherFolder) then return true end
    return false
end

local function registerScriptOwned(obj)
    if not obj then return end
    if obj:IsA("Attachment") then
        scriptAttachments[obj] = true
    elseif obj:IsA("AlignPosition") or obj:IsA("AlignOrientation") then
        scriptAlignPositions[obj] = true
    elseif obj:IsA("Torque") then
        scriptTorques[obj] = true
    elseif obj:IsA("Weld") or obj:IsA("WeldConstraint") then
        scriptWelds[obj] = true
    elseif obj:IsA("BasePart") then
        scriptParts[obj] = true
        scriptOwnedParts[obj] = true
    end
    scriptOwnedInstances[obj] = true
end

local function setupAntiTamper()
    if antiTamperRunning then return end
    antiTamperRunning = true
    -- Rapid monitor that strips foreign instances from our parts
    spawn(function()
        while antiTamperRunning do
            pcall(function()
                for part, _ in pairs(scriptOwnedParts) do
                    if part and part.Parent then
                        for _, child in ipairs(part:GetChildren()) do
                            if child:IsA("Attachment") and not scriptAttachments[child] then
                                child:Destroy()
                            elseif child:IsA("Weld") and not scriptWelds[child] then
                                child:Destroy()
                            elseif child:IsA("AlignPosition") and not scriptAlignPositions[child] then
                                child:Destroy()
                            elseif child:IsA("Torque") and not scriptTorques[child] then
                                child:Destroy()
                            elseif child:IsA("BodyVelocity") or child:IsA("BodyPosition") or child:IsA("BodyGyro") or child:IsA("BodyForce") or child:IsA("BodyThrust") or child:IsA("BodyAngularVelocity") or child:IsA("RocketPropulsion") or child:IsA("LinearVelocity") or child:IsA("AngularVelocity") then
                                child:Destroy()
                            elseif child:IsA("Constraint") and not scriptOwnedInstances[child] then
                                child:Destroy()
                            end
                        end
                        -- Clamp extreme velocity from external sources
                        if part.Velocity and part.Velocity.Magnitude > 5000 then
                            part.Velocity = part.Velocity.Unit * 5000
                        end
                        if part.RotVelocity and part.RotVelocity.Magnitude > 5000 then
                            part.RotVelocity = part.RotVelocity.Unit * 5000
                        end
                    end
                end
                for att, _ in pairs(scriptAttachments) do
                    if att and att.Parent then
                        local parent = att.Parent
                        if parent and parent:IsA("BasePart") and scriptOwnedParts[parent] then
                            if not parent:FindFirstChildOfClass("AlignPosition") then
                                local newAlign = Instance.new("AlignPosition", parent)
                                newAlign.Attachment0 = att
                                newAlign.MaxForce = PULL_MAX_FORCE
                                newAlign.MaxVelocity = math.huge
                                newAlign.Responsiveness = PULL_RESPONSIVENESS
                                scriptAlignPositions[newAlign] = true
                                scriptOwnedInstances[newAlign] = true
                            end
                            if not parent:FindFirstChildOfClass("Torque") then
                                local newTorque = Instance.new("Torque", parent)
                                newTorque.Torque = FLING_TORQUE
                                newTorque.Attachment0 = att
                                scriptTorques[newTorque] = true
                                scriptOwnedInstances[newTorque] = true
                            end
                        end
                    end
                end
            end)
            wait(0.03)
        end
    end)
    -- Nullify external ingredient/launcher scripts and body movers on workspace
    spawn(function()
        while antiTamperRunning do
            pcall(function()
                for _, v in ipairs(Workspace:GetDescendants()) do
                    if v:IsA("BodyVelocity") or v:IsA("BodyPosition") or v:IsA("BodyGyro") or v:IsA("BodyForce") or v:IsA("BodyThrust") or v:IsA("BodyAngularVelocity") or v:IsA("RocketPropulsion") or v:IsA("LinearVelocity") or v:IsA("AngularVelocity") then
                        local parent = v.Parent
                        if parent and parent:IsA("BasePart") then
                            if scriptOwnedParts[parent] and not scriptOwnedInstances[v] then
                                v:Destroy()
                            end
                        end
                    end
                    if v:IsA("Constraint") and not scriptOwnedInstances[v] then
                        local att0 = v.Attachment0
                        local att1 = v.Attachment1
                        if att0 and att0.Parent and scriptOwnedParts[att0.Parent] then v:Destroy()
                        elseif att1 and att1.Parent and scriptOwnedParts[att1.Parent] then v:Destroy() end
                    end
                end
            end)
            wait(0.05)
        end
    end)
end

-- ====== GATHER PARTS SYSTEM ======
local gatherPartsActive = false
local gatherPartsLoopRunning = false
local gatherOriginalPosition = nil
local gatherOriginalCFrame = nil
local gatheredParts = {}
local gatherFolder = nil
local GATHER_SWITCH_INTERVAL = 0.01

local function getGatherFolder()
    if not gatherFolder then
        gatherFolder = Workspace:FindFirstChild("ÆS_GatherParts_Folder")
        if not gatherFolder then
            gatherFolder = Instance.new("Folder", Workspace)
            gatherFolder.Name = "ÆS_GatherParts_Folder"
        end
    end
    return gatherFolder
end

local function getCharacterRoot()
    local character = localPlayer.Character
    if not character then return nil, nil end
    local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    return character, root
end

local function getDistantParts()
    local distantParts = {}
    local character, rootPart = getCharacterRoot()
    if not rootPart then return distantParts end

    local myPos = rootPart.Position
    -- Find furthest player distance
    local maxPlayerDist = 0
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= localPlayer and pl.Character then
            local plRoot = pl.Character:FindFirstChild("HumanoidRootPart") or pl.Character:FindFirstChild("Torso") or pl.Character:FindFirstChild("UpperTorso")
            if plRoot then
                local dist = (plRoot.Position - myPos).Magnitude
                if dist > maxPlayerDist then maxPlayerDist = dist end
            end
        end
    end

    for _, v in ipairs(Workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("BasePart") and v ~= rootPart and not v.Anchored and v.Transparency < 1 then
                -- Skip player character parts
                for _, pl in ipairs(Players:GetPlayers()) do
                    if pl.Character and v:IsDescendantOf(pl.Character) then return end
                end
                local partPos = v.Position
                local distToMe = (partPos - myPos).Magnitude
                -- Check if further from me than any other player
                local furthestFromOthers = true
                for _, pl in ipairs(Players:GetPlayers()) do
                    if pl ~= localPlayer and pl.Character then
                        local plRoot = pl.Character:FindFirstChildOfClass("HumanoidRootPart") or pl.Character:FindFirstChild("Torso") or pl.Character:FindFirstChild("UpperTorso")
                        if plRoot then
                            if (partPos - plRoot.Position).Magnitude >= distToMe then
                                furthestFromOthers = false
                                break
                            end
                        end
                    end
                end
                if furthestFromOthers or distToMe > maxPlayerDist + 10 then
                    table.insert(distantParts, v)
                end
            end
        end)
    end
    return distantParts
end

local function spinPart(part, speed)
    if not part then return end
    part.RotVelocity = Vector3.new(
        math.random(-speed, speed),
        math.random(-speed, speed),
        math.random(-speed, speed)
    )
end

local function gatherPart(part, centerAtt)
    if not part or not part.Parent then return end
    if gatheredParts[part] then return end

    gatheredParts[part] = {
        originalCFrame = part.CFrame,
        originalAnchored = part.Anchored,
        originalCanCollide = part.CanCollide,
        originalVelocity = part.Velocity,
        originalRotVelocity = part.RotVelocity,
        originalMassless = part.Massless,
    }
    scriptOwnedParts[part] = true
    local att = Instance.new("Attachment", part)
    att.Name = "GatherAtt_" .. math.random(10000,99999)
    registerScriptOwned(att)
    local alignPos = Instance.new("AlignPosition", part)
    alignPos.Attachment0 = att
    alignPos.MaxForce = 1e9
    alignPos.MaxVelocity = math.huge
    alignPos.Responsiveness = 200
    registerScriptOwned(alignPos)
    if centerAtt then
        alignPos.Attachment1 = centerAtt
    end
    local torque = Instance.new("Torque", part)
    torque.Torque = Vector3.new(5e5, 5e5, 5e5)
    torque.Attachment0 = att
    registerScriptOwned(torque)
    part.Massless = true
    part.Anchored = false
    part.CanCollide = false

    -- Tween the part into position
    local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local goal = {CFrame = centerAtt and centerAtt.WorldCFrame or part.CFrame}
    local tween = TweenService:Create(part, tweenInfo, goal)
    tween:Play()

    return att, alignPos, torque
end

local function startGatherParts()
    if gatherPartsActive then return end
    if gatherPartsLoopRunning then return end
    gatherPartsActive = true

    local character, rootPart = getCharacterRoot()
    if not rootPart then gatherPartsActive = false; return end

    gatherOriginalPosition = rootPart.Position
    gatherOriginalCFrame = rootPart.CFrame
    gatheredParts = {}
    getGatherFolder()

    -- Create a spinning center assembly above the player
    local centerPart = Instance.new("Part", getGatherFolder())
    centerPart.Name = "GatherCenter"
    centerPart.Anchored = true
    centerPart.CanCollide = false
    centerPart.Transparency = 1
    centerPart.Size = Vector3.new(1,1,1)
    centerPart.CFrame = rootPart.CFrame * CFrame.new(0, 12, 0)
    registerScriptOwned(centerPart)
    scriptParts[centerPart] = true
    scriptOwnedParts[centerPart] = true

    local centerAtt = Instance.new("Attachment", centerPart)
    centerAtt.Name = "CenterAttachment"
    registerScriptOwned(centerAtt)

    -- Spin tween for center part
    local spinTween = TweenService:Create(centerPart, TweenInfo.new(0.5, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1, true),
        {CFrame = centerPart.CFrame * CFrame.Angles(0, math.rad(360), 0)})
    spinTween:Play()

    gatherPartsLoopRunning = true
    spawn(function()
        local gatherPhase = 0
        local lastSwitch = 0
        while gatherPartsActive do
            local dt = RunService.Heartbeat:Wait() or 0.016
            gatherPhase = gatherPhase + dt

            pcall(function()
                -- Reposition center above player
                local _, hrp = getCharacterRoot()
                if hrp then
                    centerPart.CFrame = hrp.CFrame * CFrame.new(0, 12, 0)
                end

                -- Rapidly switch between distant parts every 0.01s
                if gatherPhase - lastSwitch >= GATHER_SWITCH_INTERVAL then
                    lastSwitch = gatherPhase
                    local parts = getDistantParts()
                    if #parts > 0 then
                        local idx = math.random(1, #parts)
                        local target = parts[idx]
                        if target and target.Parent and not gatheredParts[target] then
                            -- Teleport to the part
                            local _, hrp = getCharacterRoot()
                            if hrp then
                                character:SetPrimaryPartCFrame(target.CFrame * CFrame.new(0, 5, 0))
                            end
                            gatherPart(target, centerAtt)
                            spinPart(target, 80)
                        end
                    end
                end

                -- Spin gathered parts and weld them when close
                for part, data in pairs(gatheredParts) do
                    if part and part.Parent then
                        spinPart(part, 100)
                        -- Weld to center when close enough
                        if (part.Position - centerPart.Position).Magnitude < 6 then
                            if not part:FindFirstChildOfClass("Weld") then
                                local weld = Instance.new("Weld", centerPart)
                                weld.Name = "GatherWeld"
                                weld.Part0 = centerPart
                                weld.Part1 = part
                                weld.C1 = centerPart.CFrame:ToObjectSpace(part.CFrame)
                                registerScriptOwned(weld)
                                scriptWelds[weld] = true
                                -- Rapid spin via angular velocity
                                part.RotVelocity = Vector3.new(200, 200, 200)
                            end
                        end
                    else
                        gatheredParts[part] = nil
                    end
                end
            end)

            -- Auto-return after gathering sufficient parts
            if gatherPhase > 3.5 and #gatheredParts > 0 then
                break
            end
            -- Safety timeout
            if gatherPhase > 15 then
                break
            end
        end

        -- Return to original position via tween
        local _, hrp = getCharacterRoot()
        if hrp and gatherOriginalCFrame then
            local returnTween = TweenService:Create(hrp, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = gatherOriginalCFrame})
            returnTween:Play()
            returnTween.Completed:Wait(1)
        end

        -- Cleanup all gathered parts (restore original state)
        for part, data in pairs(gatheredParts) do
            pcall(function()
                if part and part.Parent then
                    for _, child in ipairs(part:GetChildren()) do
                        if scriptOwnedInstances[child] then
                            child:Destroy()
                            scriptOwnedInstances[child] = nil
                            scriptAttachments[child] = nil
                            scriptAlignPositions[child] = nil
                            scriptTorques[child] = nil
                            scriptWelds[child] = nil
                        end
                    end
                    part.CFrame = data.originalCFrame
                    part.Anchored = data.originalAnchored
                    part.CanCollide = data.originalCanCollide
                    part.Velocity = data.originalVelocity or Vector3.new(0,0,0)
                    part.RotVelocity = data.originalRotVelocity or Vector3.new(0,0,0)
                    part.Massless = data.originalMassless or false
                    scriptOwnedParts[part] = nil
                end
            end)
        end
        gatheredParts = {}

        -- Destroy gather folder contents
        if getGatherFolder() then
            for _, child in ipairs(getGatherFolder():GetChildren()) do
                pcall(function() child:Destroy() end)
            end
        end

        gatherPartsActive = false
        gatherPartsLoopRunning = false
    end)
end

