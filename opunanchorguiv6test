local globalTamperConn = Workspace.DescendantAdded:Connect(function(instance)
    if not antiTamperActive then return end
    if not instance:IsA("BasePart") then
        local parent = instance.Parent
        while parent do
            if parent:IsA("BasePart") then
                if processedParts[parent] or individualPartsData[parent] then
                    if not isScriptOwned(instance) then
                        if instance:IsA("Attachment") or instance:IsA("AlignPosition") 
                           or instance:IsA("Torque") or instance:IsA("BodyMover")
                           or instance:IsA("Weld") or instance:IsA("WeldConstraint")
                           or instance:IsA("Snap") or instance:IsA("HingeConstraint")
                           or instance:IsA("VectorForce") or instance:IsA("AngularVelocity") then
                            pcall(function() instance:Destroy() end)
                        end
                    end
                end
                break
            end
            parent = parent.Parent
        end
    end
end)

