    toggleBtn.BorderSizePixel = 0
    toggleBtn.Parent = toggleFrame
    
    local toggleCornerBtn = Instance.new("UICorner")
    toggleCornerBtn.CornerRadius = UDim.new(0, 10)
    toggleCornerBtn.Parent = toggleBtn
    
    local toggleIndicator = Instance.new("Frame")
    toggleIndicator.Name = "Indicator"
    toggleIndicator.Size = UDim2.new(0, 16, 0, 16)
    toggleIndicator.Position = UDim2.new(initialState and 1 or 0, initialState and -18 or 2, 0.5, -8)
    toggleIndicator.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    toggleIndicator.BorderSizePixel = 0
    toggleIndicator.Parent = toggleBtn
    
    local indicatorCorner = Instance.new("UICorner")
    indicatorCorner.CornerRadius = UDim.new(0, 8)
    indicatorCorner.Parent = toggleIndicator
    
    local toggled = initialState
    
    local function updateVisual()
        toggleBtn.BackgroundColor3 = toggled and COLORS.ToggleOn or COLORS.ToggleOff
        toggleIndicator:TweenPosition(
            UDim2.new(toggled and 1 or 0, toggled and -18 or 2, 0.5, -8),
            Enum.EasingDirection.InOut,
            Enum.EasingStyle.Quad,
            0.15,
            true
        )
    end
    
    toggleBtn.MouseButton1Click:Connect(function()
        toggled = not toggled
        setToggleState(stateKey, toggled)
        updateVisual()
        pcall(callback, toggled)
    end)
    
    -- Fire initial callback with restored state
    if initialState ~= defaultVal then
        pcall(callback, initialState)
    end
    
    return {
        frame = toggleFrame,
        set = function(val)
            toggled = val
            setToggleState(stateKey, val)
            updateVisual()
        end,
        get = function() return toggled end
    }
end

-- Create button
local function createActionButton(name, callback, color)
    local btnFrame = Instance.new("Frame")
    btnFrame.Name = "Btn_" .. name
    btnFrame.Size = UDim2.new(1, -10, 0, 36)
    btnFrame.BackgroundTransparency = 1
    btnFrame.Parent = scrollingFrame
    
    local btn = Instance.new("TextButton")
    btn.Name = "Button"
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundColor3 = color or COLORS.Button
    btn.Text = name
    btn.TextColor3 = COLORS.Text
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.Parent = btnFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 5)
    btnCorner.Parent = btn
    
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = COLORS.ButtonHover
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = color or COLORS.Button
    end)
    
    btn.MouseButton1Click:Connect(function()
        pcall(callback)
    end)
    
    return btnFrame
end

-- Build Toggles tab
function buildTogglesTab()
    createSectionLabel("Main Controls")
    
    createToggle("Unanchored Target All", false, function(val)
        setTargetAll(val)
    end)
    
    createToggle("Target Selected Players", false, function(val)
        setTargetSelected(val)
    end)
    
    createToggle("Individual Parts", false, function(val)
        IndividualPartsEnabled = val
        if IndividualPartsEnabled then
            if not targetAllActive and not targetSelectedActive then
                IndividualPartsEnabled = false
                return
            end
            startIndividualParts()
        else
            stopIndividualParts()
        end
    end)
    
    createToggle("Cycle", false, function(val)
        CycleMode = val
        if CycleMode then
            tryStartCycleIfNeeded()
        else
            endCycleMode()
        end
    end)
    
    createSectionLabel("Extra Settings")
    
    createToggle("PAA (player amount BHs)", false, function(val)
        PAAEnabled = val
        if PAAEnabled then
            PAA_isUsingSelected = false
            refreshPAA()
            paaConnections[#paaConnections+1] = Players.PlayerAdded:Connect(onPlayerAddedForPAA)
            paaConnections[#paaConnections+1] = Players.PlayerRemoving:Connect(onPlayerRemovingForPAA)
        else
            for _, c in ipairs(paaConnections) do pcall(function() c:Disconnect() end) end
            paaConnections = {}
            deleteBHsBySource("PAA")
        end
    end)
    
    createToggle("Skidding (0.1s fwd/back)", SkiddingEnabled, function(val)
        SkiddingEnabled = val
        if not SkiddingEnabled then
            for _, bh in ipairs(extraBlackHoles) do
                if bh then bh.skidAccumulator = 0; bh.skidState = 0 end
            end
        else
            for _, bh in ipairs(extraBlackHoles) do
                if bh then bh.skidAccumulator = 0; bh.skidState = 1 end
            end
        end
    end)
    
    createToggle("Continuous Loop Check", false, function(val)
        loopCheckActive = val
        if loopCheckActive then
            spawn(function()
                while loopCheckActive do
                    if targetAllActive or targetSelectedActive then
                        for _, v in ipairs(Workspace:GetDescendants()) do
                            if v:IsA("BasePart") and not v.Anchored and not processedParts[v] and not isPartPlayerCharacter(v) and not (localPlayer.Character and v:IsDescendantOf(localPlayer.Character)) then
                                if initiallyMasslessParts[v] == nil then pcall(function() initiallyMasslessParts[v] = v.Massless end) end
                                pcall(function() v.Massless = true end)
                                ForcePart(v)
                            end
                        end
                    end
                    wait(0.5)
                end
            end)
        end
    end)
end

-- Build Actions tab
function buildActionsTab()
    createSectionLabel("Gathering")
    
    createActionButton("Gather Parts", function()
        runGatherParts()
    end, Color3.fromRGB(50, 180, 80))
    
    createSectionLabel("Tween / Weld / Spin")
    
    createToggle("Tween/Weld/Spin Parts", false, function(val)
        tweenWeldSpinActive = val
        if tweenWeldSpinActive then
            for part, _ in pairs(processedParts) do
                if part and part.Parent then
                    local ap = part:FindFirstChildOfClass("AlignPosition")
                    if ap and ap.Attachment1 and ap.Attachment1 ~= Attachment1 then
                        for _, bh in ipairs(extraBlackHoles) do
                            if bh.Attachment == ap.Attachment1 and bh._active then
                                applyTweenWeldSpin(part, bh.Attachment)
                                setupSpinning(part)
                                break
                            end
                        end
                    end
                end
            end
        else
            for _, weld in ipairs(scriptOwnedWelds) do
                if weld and weld.Parent then
                    pcall(function() weld:Destroy() end)
                end
            end
            scriptOwnedWelds = {}
        end
    end)
    
    createSectionLabel("Cycle Controls")
    
    createActionButton("Reset Cycle", function()
        resetCycleNow()
    end, Color3.fromRGB(200, 120, 50))
    
    createSectionLabel("External Scripts")
    
    createActionButton("Load Player List Script", function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/Jlchris1/Udklol/refs/heads/main/Playerlistv6"))()
    end, Color3.fromRGB(100, 80, 180))
    
    createActionButton("Telekinesis / Fix Target", function()
        loadstring(game:HttpGet(('https://raw.githubusercontent.com/SAZXHUB/Control-update/main/README.md'), true))()
    end, Color3.fromRGB(100, 80, 180))
end

