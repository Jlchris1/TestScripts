local function createIndividualTargetAttachment(player, part)
    if not player then return nil end
    local folder = Workspace:FindFirstChild("ÆS_IndividualParts_Folder")
    if not folder then
        folder = Instance.new("Folder", Workspace)
        folder.Name = "ÆS_IndividualParts_Folder"
        markScriptOwned(folder)
    end
    local targetPart = Instance.new("Part", folder)
    targetPart.Name = "IT_" .. tostring(player.UserId)
    targetPart.Anchored = true
    targetPart.CanCollide = false
    targetPart.Transparency = 1
    targetPart.Size = Vector3.new(1,1,1)
    markScriptOwned(targetPart)
    pcall(function()
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            targetPart.CFrame = player.Character.HumanoidRootPart.CFrame
        end
    end)
    local att = Instance.new("Attachment", targetPart)
    att.Name = "TA"
    markScriptOwned(att)
    return targetPart, att
end

local function getRandomValidTarget(excludePlayer)
    local targets = {}
    local players = getAllNonLocalPlayers()
    for _, pl in ipairs(players) do
        if pl ~= excludePlayer and isPlayerAlive(pl) then
            table.insert(targets, pl)
        end
    end
    if #targets == 0 then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= localPlayer and p.Parent and isPlayerAlive(p) and p ~= excludePlayer then
                table.insert(targets, p)
            end
        end
    end
    if #targets == 0 then return nil end
    return targets[math.random(1, #targets)]
end

local function startIndividualPartFlight(part, data)
    -- Simplified flight - just follows the target attachment
    spawn(function()
        while individualPartsActive and part and part.Parent and data and data.active do
            local dt = RunService.Heartbeat:Wait()
            if not dt then dt = 0.016 end
            
            local player = data.targetPlayer
            if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and isPlayerAlive(player) then
                local hrp = player.Character.HumanoidRootPart
                local vel = hrp.Velocity or Vector3.new(0,0,0)
                local predictedPos = predictTargetPosition(player, hrp.Position, vel, tick())
                
                -- Simple orbit
                local time = tick()
                local radius = 5
                local orbit = Vector3.new(
                    math.cos(time * 2.5) * radius,
                    math.sin(time * 1.3) * 3 + 3,
                    math.sin(time * 2.5) * radius * 0.7
                )
                
                if data.targetPart and data.targetPart.Parent then
                    local targetPos = predictedPos + orbit
                    local curPos = data.targetPart.Position
                    data.targetPart.Position = curPos + (targetPos - curPos) * clamp(dt * 8, 0, 0.3)
                end
            end
            
            -- Periodically switch targets (every 2 seconds)
            if data.nextSwitchTime and tick() >= data.nextSwitchTime then
                if not data.switchingLock then
                    data.switchingLock = true
                    spawn(function()
                        wait(0.05)
                        if data and individualPartsActive then
                            local newPlayer = getRandomValidTarget(data.targetPlayer)
                            if newPlayer then
                                data.targetPlayer = newPlayer
                                if data.targetPart and data.targetPart.Parent then
                                    pcall(function() data.targetPart:Destroy() end)
                                end
                                local tp, ta = createIndividualTargetAttachment(newPlayer, part)
                                if tp and ta then
                                    data.targetPart = tp
                                    data.targetAttachment = ta
                                    if data.alignPos then
                                        pcall(function() data.alignPos.Attachment1 = ta end)
                                    end
                                end
                            end
                        end
                        if data then
                            data.switchingLock = false
                            data.nextSwitchTime = tick() + 2 + math.random() * 2
                        end
                    end)
                end
            end
        end
        if data then data.thread = nil end
    end)
end

local function ForcePartIndividual(v)
    if not v or not v:IsA("BasePart") then return end
    if isPartPlayerCharacter(v) then return end
    if localPlayer.Character and v:IsDescendantOf(localPlayer.Character) then return end
    
    if v:IsA("BasePart") and not v.Anchored and v.Name ~= "Handle"
        and (
            (v.Parent:FindFirstChildOfClass("Humanoid") and isNPC(v.Parent))
            or (not v.Parent:FindFirstChildOfClass("Humanoid") and not v.Parent:FindFirstChild("Head"))
        ) then
        
        if processedParts[v] then return end
        processedParts[v] = true
        if individualPartsData[v] then return end
        
        if initiallyMasslessParts[v] == nil then
            pcall(function() initiallyMasslessParts[v] = v.Massless end)
        end
        pcall(function() v.Massless = true end)
        
        stripBodyForces(v)
        v.CanCollide = false
        
        local partAtt = Instance.new("Attachment", v)
        markScriptOwned(partAtt)
        
        local alignPos = Instance.new("AlignPosition", v)
        markScriptOwned(alignPos)
        alignPos.Attachment0 = partAtt
        
        alignPos.MaxForce = PULL_MAX_FORCE * MASSLESS_PULL_SCALE
        alignPos.MaxVelocity = math.huge
        alignPos.Responsiveness = PULL_RESPONSIVENESS * MASSLESS_RESP_SCALE
        
        local torque = Instance.new("Torque", v)
        markScriptOwned(torque)
        torque.Torque = FLING_TORQUE * MASSLESS_TORQUE_SCALE
        torque.Attachment0 = partAtt
        
        setupAntiTamper(v)
        
        local initialPlayer = getRandomValidTarget(nil)
        if not initialPlayer then
            alignPos.Attachment1 = Attachment1
            return
        end
        
        local targetPart, targetAtt = createIndividualTargetAttachment(initialPlayer, v)
        if targetAtt then
            alignPos.Attachment1 = targetAtt
        else
            alignPos.Attachment1 = Attachment1
        end
        
        local data = {
            part = v,
            attachment = partAtt,
            alignPos = alignPos,
            torque = torque,
            targetPlayer = initialPlayer,
            targetPart = targetPart,
            targetAttachment = targetAtt,
            nextSwitchTime = tick() + 2 + math.random() * 2,
            active = true,
            switchingLock = false,
        }
        
        individualPartsData[v] = data
        startIndividualPartFlight(v, data)
    end
end

local function startIndividualParts()
    if individualPartsActive then return end
    individualPartsActive = true
    antiTamperActive = true
    
    -- Use throttled scan for initial parts
    throttledDescendantScan(function(v)
        if v:IsA("BasePart") and not v.Anchored and v.Name ~= "Handle"
            and not isPartPlayerCharacter(v)
            and not (localPlayer.Character and v:IsDescendantOf(localPlayer.Character))
            and (
                (v.Parent:FindFirstChildOfClass("Humanoid") and isNPC(v.Parent))
                or (not v.Parent:FindFirstChildOfClass("Humanoid") and not v.Parent:FindFirstChild("Head"))
            ) then
            if initiallyMasslessParts[v] == nil then
                pcall(function() initiallyMasslessParts[v] = v.Massless end)
            end
            pcall(function() v.Massless = true end)
            ForcePartIndividual(v)
        end
    end, 40)
    
    -- Simplified loop check - much less frequent
    if not individualPartsLoopRunning then
        individualPartsLoopRunning = true
        spawn(function()
            while individualPartsActive do
                wait(1) -- Much slower check (was 0.3)
                if not individualPartsActive then break end
                local count = 0
                for _, v in ipairs(Workspace:GetDescendants()) do
                    if not individualPartsActive then break end
                    count = count + 1
                    if count > 100 then wait(); count = 0 end
                    if PERFORMANCE_MODE then wait(0.05) end
                    
                    if v:IsA("BasePart") and not v.Anchored and not processedParts[v]
                        and not individualPartsData[v] and v.Name ~= "Handle"
                        and not isPartPlayerCharacter(v)
                        and not (localPlayer.Character and v:IsDescendantOf(localPlayer.Character))
                        and (
                            (v.Parent:FindFirstChildOfClass("Humanoid") and isNPC(v.Parent))
                            or (not v.Parent:FindFirstChildOfClass("Humanoid") and not v.Parent:FindFirstChild("Head"))
                        ) then
                        if initiallyMasslessParts[v] == nil then
                            pcall(function() initiallyMasslessParts[v] = v.Massless end)
                        end
                        pcall(function() v.Massless = true end)
                        ForcePartIndividual(v)
                    end
                end
            end
            individualPartsLoopRunning = false
        end)
    end
end

local function stopIndividualParts()
    individualPartsActive = false
    
    for part, data in pairs(individualPartsData) do
        pcall(function()
            if data.targetPart and data.targetPart.Parent then
                data.targetPart:Destroy()
            end
            if part and part.Parent then
                stripBodyForces(part)
                part.CanCollide = true
                if initiallyAnchoredParts[part] == false then
                    part.Anchored = false
                elseif initiallyAnchoredParts[part] == true then
                    part.Anchored = true
                end
                if initiallyMasslessParts[part] ~= nil then
                    pcall(function() part.Massless = initiallyMasslessParts[part] end)
                else
                    pcall(function() part.Massless = false end)
                end
            end
        end)
    end
    
    individualPartsData = {}
    
    local folder = Workspace:FindFirstChild("ÆS_IndividualParts_Folder")
    if folder then
        for _, child in ipairs(folder:GetChildren()) do
            pcall(function() child:Destroy() end)
        end
    end
    
    processedParts = {}
    antiTamperActive = false
end

-- ForcePart - optimized
local function ForcePart(v)
    if IndividualPartsEnabled then
        ForcePartIndividual(v)
        return
    end
    
    if not v or not v:IsA("BasePart") then return end
    if isPartPlayerCharacter(v) then return end
    if localPlayer.Character and v:IsDescendantOf(localPlayer.Character) then return end

    if v:IsA("BasePart") and not v.Anchored and v.Name ~= "Handle"
        and (
            (v.Parent:FindFirstChildOfClass("Humanoid") and isNPC(v.Parent))
            or (not v.Parent:FindFirstChildOfClass("Humanoid") and not v.Parent:FindFirstChild("Head"))
        ) then

        if processedParts[v] then return end
        processedParts[v] = true

        if initiallyMasslessParts[v] == nil then
            pcall(function() initiallyMasslessParts[v] = v.Massless end)
        end
        pcall(function() v.Massless = true end)

        stripBodyForces(v)
        v.CanCollide = false

        local Attachment2 = Instance.new("Attachment", v)
        markScriptOwned(Attachment2)

        local AlignPosition = Instance.new("AlignPosition", v)
        markScriptOwned(AlignPosition)
        AlignPosition.Attachment0 = Attachment2

        AlignPosition.MaxForce = PULL_MAX_FORCE
        AlignPosition.MaxVelocity = math.huge
        AlignPosition.Responsiveness = PULL_RESPONSIVENESS

        local Torque = Instance.new("Torque", v)
        markScriptOwned(Torque)
        Torque.Torque = FLING_TORQUE
        Torque.Attachment0 = Attachment2
        
        setupAntiTamper(v)

        local bh = getLeastLoadedBlackHole()
        if bh and bh.Attachment and bh._active then
            AlignPosition.Attachment1 = bh.Attachment
            table.insert(bh.AssignedParts, v)
            
            if tweenWeldSpinActive then
                applyTweenWeldSpin(v, bh.Attachment)
                setupSpinning(v)
            end
        else
            AlignPosition.Attachment1 = Attachment1
        end
    end
end

local function clearProcessedParts()
    if individualPartsActive then
        stopIndividualParts()
    end
    
    for part, _ in pairs(processedParts) do
        if part and part.Parent then
            stripBodyForces(part)
            part.CanCollide = true
            if initiallyAnchoredParts[part] == false then
                part.Anchored = false
            elseif initiallyAnchoredParts[part] == true then
                part.Anchored = true
            end
            if initiallyMasslessParts[part] ~= nil then
                pcall(function() part.Massless = initiallyMasslessParts[part] end)
            else
                pcall(function() part.Massless = false end)
            end
        end
    end
    processedParts = {}
    initiallyAnchoredParts = {}
    initiallyMasslessParts = {}
    anchoredOnce = false
end

local function anchorAndDelayedUnanchorParts()
    unanchorTimerRunning = true

    local candidateParts = {}
    -- Limit scan to avoid lag
    local scanned = 0
    for _, v in ipairs(Workspace:GetDescendants()) do
        scanned = scanned + 1
        if scanned > 5000 then break end -- Cap scan size
        
        if v:IsA("BasePart") and not v.Anchored and v.Name ~= "Handle"
            and not isPartPlayerCharacter(v)
            and not (localPlayer.Character and v:IsDescendantOf(localPlayer.Character))
            and (
                (v.Parent:FindFirstChildOfClass("Humanoid") and isNPC(v.Parent))
                or (not v.Parent:FindFirstChildOfClass("Humanoid") and not v.Parent:FindFirstChild("Head"))
            ) then
            table.insert(candidateParts, v)
        end
        if #candidateParts >= 500 then break end -- Limit parts processed
    end

    initiallyAnchoredParts = {}
    for _, part in ipairs(candidateParts) do
        initiallyAnchoredParts[part] = false
        if initiallyMasslessParts[part] == nil then
            pcall(function() initiallyMasslessParts[part] = part.Massless end)
        end
        pcall(function() part.Massless = true end)
        part.Anchored = true
        part.CanCollide = false
        wait() -- Yield per part to prevent lag
    end

    local startTime = tick()
    while (targetAllActive or targetSelectedActive) and tick() - startTime < 1 do
        wait(0.05)
    end

    for _, part in ipairs(candidateParts) do
        if part and part.Parent and initiallyAnchoredParts[part] == false then
            part.Anchored = false
            pcall(function()
                if not isPartPlayerCharacter(part) then
                    initiallyMasslessParts[part] = initiallyMasslessParts[part] or part.Massless
                    part.Massless = true
                end
            end)
            ForcePart(part)
            wait() -- Yield per part
        end
    end

    unanchorTimerRunning = false
    anchoredOnce = true
end

local descendantAddedConn
local function processWorkspaceParts()
    if descendantAddedConn then
        descendantAddedConn:Disconnect()
        descendantAddedConn = nil
    end

    if (targetAllActive or targetSelectedActive) then
        if not unanchorTimerRunning and not anchoredOnce then
            unanchorCoroutine = coroutine.create(anchorAndDelayedUnanchorParts)
            coroutine.resume(unanchorCoroutine)
        end

        -- Throttled descendant added handler - only process every N additions
        local addCount = 0
        descendantAddedConn = Workspace.DescendantAdded:Connect(function(v)
            if not (targetAllActive or targetSelectedActive) then return end
            addCount = addCount + 1
            -- Only process every 5th addition to reduce load
            if addCount % 5 ~= 0 then return end
            if #processedParts > 1000 then return end -- Cap total processed parts
            
            if v:IsA("BasePart") and not v.Anchored and not processedParts[v]
                and not isPartPlayerCharacter(v)
                and not (localPlayer.Character and v:IsDescendantOf(localPlayer.Character)) then
                if initiallyMasslessParts[v] == nil then
                    pcall(function() initiallyMasslessParts[v] = v.Massless end)
                end
                pcall(function() v.Massless = true end)
                ForcePart(v)
            end
        end)
    end
end

