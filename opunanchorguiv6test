local function applyTweenWeldSpin(part, attachment)
    if not part or not attachment then return end
    
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
    local goal = {
        CFrame = attachment.WorldCFrame * CFrame.new(0, 0.5, 0)
    }
    local tween = TweenService:Create(part, tweenInfo, goal)
    tween:Play()
    markScriptOwned(tween)
    
    local weld = Instance.new("WeldConstraint")
    weld.Name = "BH_Weld_" .. tostring(math.random(10000, 99999))
    weld.Part0 = part
    weld.Part1 = attachment.Parent
    weld.Parent = part
    markScriptOwned(weld)
    table.insert(scriptOwnedWelds, weld)
    
    if not part:FindFirstChild("BH_Welds") then
        local weldFolder = Instance.new("Folder", part)
        weldFolder.Name = "BH_Welds"
        markScriptOwned(weldFolder)
    end
    local wf = part:FindFirstChild("BH_Welds")
    if wf then
        weld.Parent = wf
    end
    
    return weld
end

local function setupSpinning(part)
    local att = part:FindFirstChildOfClass("Attachment")
    if not att then
        att = Instance.new("Attachment", part)
        markScriptOwned(att)
    end
    
    local torque = Instance.new("Torque", part)
    torque.Attachment0 = att
    torque.Torque = Vector3.new(50000, 50000, 50000) * (1 + math.random() * 2)
    markScriptOwned(torque)
    
    local angVel = Instance.new("AngularVelocity", part)
